---
export interface PanelMedia {
  type?: "image" | "video";
  src?: string;
  webm?: string;
  mp4?: string;
  poster?: string;
  alt?: string;
}

export interface PanelCta {
  label: string;
  href: string;
}

export interface Props {
  media?: PanelMedia;
  eyebrow?: string;
  title: string;
  body?: string;
  signature?: string;
  cta?: PanelCta;
  align?: "bottom-left" | "bottom-center";
  priority?: boolean;
}

const {
  media,
  title,
  body,
  signature,
  cta,
  align = "bottom-left",
  priority = false,
} = Astro.props as Props;

const isVideo = media?.type === "video";
const hasVideo = isVideo && (media?.webm || media?.mp4);
const hasImage = !isVideo && !!media?.src;
const fallbackImage = media?.poster ?? "/hero-loop-poster.jpg";
const contentClass = align === "bottom-center"
  ? "items-end justify-center text-center"
  : "items-end justify-start text-left";
const innerClass = align === "bottom-center"
  ? "items-center px-10 pb-12 md:pb-16"
  : "items-start px-10 pb-12 md:px-12 md:pb-16";
---

<section class="home-media-panel relative min-h-[76svh] w-full overflow-hidden bg-ink md:min-h-[86vh]">
  {hasVideo ? (
    <>
      <video
        class="absolute inset-0 h-full w-full object-cover"
        autoplay
        muted
        loop
        playsinline
        preload={priority ? "auto" : "metadata"}
        poster={fallbackImage}
        aria-hidden="true"
      >
        {media?.webm && <source src={media.webm} type="video/webm" />}
        {media?.mp4 && <source src={media.mp4} type="video/mp4" />}
      </video>
      <img
        src={fallbackImage}
        alt=""
        class="home-media-poster hidden absolute inset-0 h-full w-full object-cover"
        aria-hidden="true"
      />
    </>
  ) : (
    <img
      src={hasImage ? media!.src : fallbackImage}
      alt={media?.alt ?? ""}
      class="absolute inset-0 h-full w-full object-cover"
      loading={priority ? "eager" : "lazy"}
      aria-hidden={!media?.alt ? "true" : undefined}
    />
  )}

  <div
    class="pointer-events-none absolute inset-0"
    style="background: linear-gradient(to top, rgba(10,10,10,0.62) 0%, rgba(10,10,10,0.12) 48%, rgba(10,10,10,0.08) 100%);"
    aria-hidden="true"
  ></div>

  <div class:list={["relative z-10 flex min-h-[76svh] w-full md:min-h-[86vh]", contentClass]}>
    <div class:list={["flex flex-col", innerClass]} style="max-width: 34rem;">
      <h2 class="m-0 font-display text-[clamp(1.34rem,2.5vw,2.15rem)] font-bold leading-[1.05] tracking-normal text-paper">
        {title}
      </h2>
      {body && (
        <p class="mt-5 font-sans text-base font-semibold leading-relaxed text-paper/85 md:text-lg">
          {body}
        </p>
      )}
      {signature && (
        <p class="mt-5 font-sans text-sm font-semibold text-paper/75">
          {signature}
        </p>
      )}
      {cta && (
        <a
          href={cta.href}
          class="home-panel-cta mt-6 inline-flex min-h-[3.05rem] w-fit items-center justify-center px-7 font-display text-[0.72rem] font-semibold uppercase text-paper focus:outline-none focus:ring-2 focus:ring-paper focus:ring-offset-2 focus:ring-offset-ink"
          style="background-color: color-mix(in srgb, var(--color-muted) 78%, var(--color-ink));"
          aria-label={cta.label}
        >
          {cta.label}
        </a>
      )}
    </div>
  </div>
</section>

{hasVideo && (
  <script>
    (function () {
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
      const videos = Array.from(document.querySelectorAll(".home-media-panel video"));
      if (reduce.matches) {
        videos.forEach((video) => {
          (video as HTMLVideoElement).style.display = "none";
          video.parentElement?.querySelector(".home-media-poster")?.classList.remove("hidden");
        });
      }
    })();
  </script>
)}

<style>
  .home-panel-cta {
    position: relative;
    transition:
      background-color var(--duration-standard) var(--ease-standard),
      color var(--duration-standard) var(--ease-standard);
  }
</style>
