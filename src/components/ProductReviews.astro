---
export interface Props {
  productTitle?: string;
}

const reviews = [
  {
    name: "Steven Price",
    source: "Customer note",
    quote: "Just wanted to say I finally got my order, love the designs!",
  },
  {
    name: "Briana DiIorio",
    source: "Customer note",
    quote: "My husband just received his shirt. He absolutely loves it.",
  },
];
---

<section id="reviews" class="border-t border-line bg-paper px-6 py-12 md:px-8 lg:px-10">
  <div class="grid gap-10 lg:grid-cols-[minmax(0,38fr)_minmax(0,62fr)]">
    <div>
      <h2 class="font-sans text-2xl font-semibold leading-tight tracking-normal text-ink">
        Customer Reviews
      </h2>
      <p class="mt-3 font-sans text-sm leading-relaxed text-muted">
        Recent notes from customers after receiving their Revenant Edge orders.
      </p>
    </div>

    <div class="grid gap-px bg-line md:grid-cols-2">
      {reviews.map((review) => (
        <article class="bg-paper p-5">
          <div class="flex items-center justify-between gap-4">
            <h3 class="font-sans text-sm font-semibold tracking-normal text-ink">{review.name}</h3>
            <span class="font-sans text-sm tracking-[0.08em] text-ink" aria-label="5 out of 5 stars">★★★★★</span>
          </div>
          <p class="mt-1 font-sans text-xs font-semibold text-muted">{review.source}</p>
          <p class="mt-5 font-sans text-sm leading-relaxed text-ink">
            "{review.quote}"
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
