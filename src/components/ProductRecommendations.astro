---
import { getCollectionByHandle, getProductRecommendations } from "../utils/shopify";
import { isCollection2ProductHandle } from "../utils/collections";
import ProductCard from "./ProductCard.astro";

export interface Props {
  productId: string;
  buyerIP: string;
  heading?: string;
  collectionHandle?: string;
  collectionHref?: string;
  collectionGroup?: "collection-1" | "collection-2";
  ctaLabel?: string;
}

const {
  productId,
  buyerIP,
  heading = "Style With",
  collectionHandle,
  collectionHref = "/collections/shop-all",
  collectionGroup,
  ctaLabel = "Shop All",
} = Astro.props as Props;

const collection = collectionHandle
  ? await getCollectionByHandle({ handle: collectionHandle, limit: 12, buyerIP }).catch(() => null)
  : null;
function productMatchesCollectionGroup(handle: string) {
  if (!collectionGroup) return true;

  const isCollection2 = isCollection2ProductHandle(handle);
  return collectionGroup === "collection-2" ? isCollection2 : !isCollection2;
}

const collectionProducts =
  collection?.products.nodes.filter((product) => (
    product.id !== productId && productMatchesCollectionGroup(product.handle)
  )) ?? [];
const productRecommendations = collectionHandle
  ? collectionProducts
  : await getProductRecommendations({
      productId,
      buyerIP,
    });
---

<section class="border-t border-line py-12 sm:py-16">
  <div class="mb-5 flex items-center justify-end px-6 md:px-8">
    <a href={collectionHref} class="nav-label text-ink underline underline-offset-4">{ctaLabel}</a>
  </div>
  <div class="px-6 md:px-8">
    <h2 class="sr-only">Products to style with this item</h2>
    {
      productRecommendations.length > 0 ? (
        <div class="grid grid-cols-2 gap-x-1 gap-y-8 md:grid-cols-3 xl:grid-cols-4">
          {productRecommendations.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
      ) : (
        <div class="flex min-h-[180px] items-center justify-center bg-surface px-6 text-center">
          <a href={collectionHref} class="font-sans text-sm font-semibold text-ink underline underline-offset-4">
            {ctaLabel}
          </a>
        </div>
      )
    }
  </div>
</section>
