---
import type { z } from "zod";
import type { ProductResult } from "../utils/schemas";

import Money from "./Money.svelte";

export interface Props {
  product: z.infer<typeof ProductResult>;
  colorProducts?: NonNullable<z.infer<typeof ProductResult>>[];
}
const { product, colorProducts = [] } = Astro.props as Props;

const PRODUCT_CARD_IMAGE_OVERRIDES: Record<
  string,
  {
    primary: { url: string; width: number; height: number; altText: string };
    secondary?: { url: string; width: number; height: number; altText: string };
  }
> = {
  "light-within-the-dark-hoodie-black": {
    primary: {
      url: "/images/product-overrides/light-within-the-dark-hoodie-back-white.png",
      width: 1080,
      height: 1080,
      altText: "Light Within The Dark Hoodie Black Back",
    },
    secondary: {
      url: "/images/product-overrides/light-within-the-dark-hoodie-front-white.png",
      width: 1080,
      height: 1080,
      altText: "Light Within The Dark Hoodie Black Front",
    },
  },
};
const imageOverride = product ? PRODUCT_CARD_IMAGE_OVERRIDES[product.handle] : null;
const primaryImage = imageOverride?.primary ?? product?.featuredImage ?? product?.images?.nodes?.[0] ?? null;
const secondaryImage = imageOverride?.secondary ?? product?.images?.nodes?.[1] ?? null;
const hasSwap = !!secondaryImage;
const COLOR_SWATCHES: Record<string, string> = {
  black: "#0A0A0A",
  white: "#FFFFFF",
  cobalt: "#2747B8",
  storm: "#777D88",
  mushroom: "#B9AC9B",
  ash: "#D3D3D3",
  cream: "#E8E1D2",
};
const COLOR_NAMES = Object.keys(COLOR_SWATCHES);

function titleCase(value: string) {
  return value.charAt(0).toUpperCase() + value.slice(1);
}

function inferProductColor(target: NonNullable<z.infer<typeof ProductResult>>) {
  const source = [
    target.title,
    target.handle,
    target.featuredImage?.altText,
    target.featuredImage?.url,
  ].filter(Boolean).join(" ").toLowerCase();

  const match = COLOR_NAMES.find((name) => {
    const pattern = new RegExp(`(^|[^a-z])${name}([^a-z]|$)`, "i");
    return pattern.test(source);
  });

  return match ? titleCase(match) : "White";
}

const currentColor = product ? inferProductColor(product) : "White";
const familyProducts = (colorProducts.length > 0 && product ? colorProducts : product ? [product] : [])
  .filter(Boolean)
  .sort((a, b) => {
    const order = ["White", "Black"];
    return order.indexOf(inferProductColor(a)) - order.indexOf(inferProductColor(b));
  });
const swatches = familyProducts.map((familyProduct) => ({
  color: inferProductColor(familyProduct),
  href: `/products/${familyProduct.handle}`,
}));

// Build Shopify-optimised src for a given image + width
function imgSrc(url: string, width: number) {
  if (url.startsWith("/")) return url;
  return `${url}&width=${width}`;
}
---

<article class="product-card group block">
  <a
    href={`/products/${product?.handle}`}
    aria-label={`View ${product?.title}`}
    class="product-card__image-wrap relative block aspect-[187/251] overflow-hidden bg-paper transition-all duration-[280ms] group-hover:z-10"
  >

    {primaryImage && (
      <img
        src={imgSrc(primaryImage.url, 800)}
        alt={primaryImage.altText || product?.title || "Product image"}
        width={primaryImage.width}
        height={primaryImage.height}
        loading="lazy"
        sizes="(min-width: 1280px) 25vw, (min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
        srcset={[450, 600, 800, 1000].map(w => `${imgSrc(primaryImage.url, w)} ${w}w`).join(", ")}
        class:list={[
          "product-card__img product-card__img--primary",
          "absolute inset-0 w-full h-full object-contain p-[12%] md:p-[14%]",
          "transition-opacity duration-[280ms]",
          hasSwap
            ? "group-hover:opacity-0"
            : "group-hover:scale-[1.02] transition-transform",
        ]}
        style={`transition-timing-function: var(--ease-standard);`}
      />
    )}

    {hasSwap && secondaryImage && (
      <img
        src={imgSrc(secondaryImage.url, 800)}
        alt={secondaryImage.altText || `${product?.title}, alternate view`}
        width={secondaryImage.width}
        height={secondaryImage.height}
        loading="lazy"
        sizes="(min-width: 1280px) 25vw, (min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
        srcset={[450, 600, 800, 1000].map(w => `${imgSrc(secondaryImage.url, w)} ${w}w`).join(", ")}
        class="product-card__img product-card__img--secondary
               absolute inset-0 w-full h-full object-contain p-[12%] md:p-[14%]
               opacity-0 group-hover:opacity-100
               transition-opacity duration-[280ms]"
        style="transition-timing-function: var(--ease-standard);"
      />
    )}

    <span class="absolute bottom-4 right-4 font-sans text-2xl font-light leading-none text-ink" aria-hidden="true">
      +
    </span>
  </a>

  <div class="product-card__meta px-4 pb-7 pt-5 md:px-5">
    <div class="flex items-start justify-between gap-4">
      <h3 class="font-sans text-[13px] font-semibold leading-snug text-ink normal-case">
        <a href={`/products/${product?.handle}`} class="product-card__title">
          {product?.title}
        </a>
      </h3>
      <p class="product-card__price shrink-0 font-sans text-[13px] font-semibold leading-snug text-ink">
        <Money price={product?.variants.nodes[0].price} />
      </p>
    </div>

    <p class="mt-2 font-sans text-[13px] font-semibold leading-snug text-muted">
      {currentColor}
    </p>

    <div class="mt-3 flex items-center gap-2" aria-label={`${product?.title} colors`}>
      {swatches.map((color) => (
        <a href={color.href} aria-label={`View ${product?.title} in ${color.color}`}>
          <span
            class:list={[
              "block h-[13px] w-[13px] rounded-full border",
              currentColor === color.color ? "border-ink" : "border-line",
            ]}
            style={`background-color: ${COLOR_SWATCHES[color.color.toLowerCase()] ?? "var(--color-ink)"};`}
            title={color.color}
          ></span>
        </a>
      ))}
      <span class="font-sans text-[13px] font-semibold leading-none text-muted">
        {swatches.length} {swatches.length === 1 ? "Color" : "Colors"}
      </span>
    </div>
  </div>
</article>

<style>
  .product-card__img--primary {
    will-change: transform, opacity;
  }
  .product-card__img--secondary {
    will-change: opacity;
  }
</style>
