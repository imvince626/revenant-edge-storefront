---
/**
 * Header.astro — Revenant Edge premium minimalist header
 *
 * Props:
 *   solidFromTop?: boolean  - When true, header renders in solid bg-paper/ink state
 *                             immediately (for non-hero pages: /styleguide, product detail, etc.)
 *                             Default: false (transparent over dark hero, transitions to solid on scroll)
 */
import CartIcon from "./CartIcon.svelte";
import MobileNav from "./MobileNav.svelte";

interface Props {
  solidFromTop?: boolean;
}

const { solidFromTop = false } = Astro.props;

const collectionLinks = [
  { label: "Shop Children of the Sea", href: "/collections/collection-1-children-of-the-sea" },
  { label: "Shop Demon Slayer", href: "/collections/demon-slayer" },
  { label: "Lookbook", href: "/blogs/lookbook" },
  { label: "Behind the Brand", href: "/about" },
];

const contactLink = { label: "Contact", href: "/contact" };
---

<header
  id="site-header"
  class:list={[
    "left-0 right-0 z-50 transition-all",
    solidFromTop ? "relative" : "absolute",
  ]}
  style={`top: ${solidFromTop ? "auto" : "var(--announcement-bar-height, 34px)"}; transition-property: background-color, border-color, color; transition-duration: 280ms; transition-timing-function: cubic-bezier(0.4,0,0.2,1);`}
  data-solid-from-top={solidFromTop ? "true" : "false"}
>
  <div class="mx-auto flex h-16 max-w-none items-center px-4 md:px-6 lg:px-8">

    <nav class="hidden flex-1 items-center gap-4 lg:gap-6 md:flex" aria-label="Primary navigation">
      <div class="mega-trigger" data-mega-trigger>
        <a href="/collections/shop-all" class="nav-label header-nav-link header-nav-link--active">Shop</a>
        <div class="mega-menu" aria-label="Shop menu">
          <div class="mega-menu__inner">
            <nav class="mega-menu__links" aria-label="Shop menu links">
              <div class="grid gap-5">
                {collectionLinks.map((link) => (
                  <a href={link.href} class="mega-menu__sub-link">
                    <span>{link.label}</span>
                    <span aria-hidden="true">›</span>
                  </a>
                ))}
              </div>
              <a href={contactLink.href} class="mega-menu__contact">{contactLink.label}</a>
            </nav>
          </div>
        </div>
      </div>
    </nav>

    <div class="flex flex-1 items-center md:hidden">
      <MobileNav client:load />
    </div>

    <a
      href="/"
      class="absolute left-1/2 -translate-x-1/2 md:relative md:left-auto md:shrink-0 md:translate-x-0 md:px-4 lg:px-6"
      aria-label="Revenant Edge home"
    >
      <img
        src="/logo-mark-white.png"
        alt="Revenant Edge"
        class="header-logo-white h-[34px] w-auto"
        width="98"
        height="30"
        loading="eager"
        fetchpriority="high"
      />
      <img
        src="/logo-mark-ink.png"
        alt="Revenant Edge"
        class="header-logo-black h-[34px] w-auto"
        width="98"
        height="30"
        loading="eager"
        fetchpriority="high"
      />
    </a>

    <div class="flex flex-1 items-center justify-end gap-4 lg:gap-6">
      <nav class="hidden items-center gap-4 lg:gap-6 md:flex" aria-label="Secondary navigation">
        <a href="/retail" class="nav-label header-nav-link">Retail</a>
        <a href="/about" class="nav-label header-nav-link">About Us</a>
        <span class="nav-label header-nav-link">US / USD</span>
      </nav>

      <CartIcon client:load />
    </div>
  </div>

  <div class="header-border absolute bottom-0 left-0 right-0 h-px origin-left scale-x-0 transition-all duration-[280ms]" style="background-color: var(--color-line);"></div>
</header>

<style>
  /*
   * Transparent hero state.
   * Header background: transparent; content: paper (white)
   */
  #site-header {
    background-color: transparent;
    color: var(--color-paper);
  }
  #site-header .header-logo-white { display: block; }
  #site-header .header-logo-black { display: none; }
  #site-header .header-border { transform: scaleX(0); }

  /*
   * Solid state for pages without a dark hero.
   */
  #site-header[data-solid-from-top="true"] {
    background-color: var(--color-paper);
    color: var(--color-ink);
  }
  #site-header[data-solid-from-top="true"] .header-logo-white { display: none; }
  #site-header[data-solid-from-top="true"] .header-logo-black { display: block; }
  #site-header[data-solid-from-top="true"] .header-border { transform: scaleX(1); }

  /* Nav link hover: ember underline */
  .header-nav-link {
    position: relative;
    font-size: 10px;
    line-height: 1;
    transition: opacity 180ms;
    white-space: nowrap;
  }

  @media (min-width: 1024px) {
    .header-nav-link {
      font-size: 11px;
    }
  }
  .header-nav-link::after {
    content: "";
    position: absolute;
    bottom: -3px;
    left: 0;
    right: 0;
    height: 1px;
    background-color: var(--color-ember);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .header-nav-link:hover::after {
    transform: scaleX(1);
  }
  .header-nav-link:hover {
    opacity: 0.8;
  }

  .mega-trigger {
    display: flex;
    height: 4rem;
    align-items: center;
  }

  .mega-trigger::after {
    content: "";
    pointer-events: none;
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    z-index: 49;
    height: 1rem;
  }

  .mega-menu {
    pointer-events: none;
    visibility: hidden;
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    z-index: 48;
    max-height: calc(100vh - var(--announcement-bar-height, 34px) - 4rem);
    overflow-y: auto;
    border-top: 1px solid var(--color-line);
    background: var(--color-paper);
    color: var(--color-ink);
    opacity: 0;
    transform: translateY(-0.35rem);
    transition:
      opacity 220ms var(--ease-standard) 120ms,
      transform 220ms var(--ease-standard) 120ms,
      visibility 0ms linear 340ms;
  }

  .mega-trigger:hover::after,
  .mega-trigger:focus-within::after {
    pointer-events: auto;
  }

  .mega-trigger:hover .mega-menu,
  .mega-trigger:focus-within .mega-menu,
  .mega-trigger.is-open .mega-menu {
    pointer-events: auto;
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0ms, 0ms, 0ms;
  }

  .mega-menu__inner {
    max-width: 34rem;
    padding: 3.25rem 2rem 4rem;
  }

  .mega-menu__links {
    display: block;
  }

  .mega-menu__sub-link:hover {
    opacity: 0.55;
  }

  .mega-menu__sub-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.1;
    transition: opacity 160ms var(--ease-standard);
  }

  .mega-menu__contact {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 2.25rem;
    min-width: 9rem;
    min-height: 2.75rem;
    padding: 0 1.25rem;
    background: var(--color-ink);
    color: var(--color-paper);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
    transition: opacity 160ms var(--ease-standard);
  }

  .mega-menu__contact:hover {
    opacity: 0.72;
  }

  @media (max-width: 767px) {
    .mega-menu {
      display: none;
    }
  }
</style>

<script>
  document.querySelectorAll("[data-mega-trigger]").forEach((trigger) => {
    let openTimer;
    let closeTimer;

    function openMenu() {
      window.clearTimeout(closeTimer);
      openTimer = window.setTimeout(() => {
        trigger.classList.add("is-open");
      }, 60);
    }

    function closeMenu() {
      window.clearTimeout(openTimer);
      closeTimer = window.setTimeout(() => {
        trigger.classList.remove("is-open");
      }, 260);
    }

    trigger.addEventListener("pointerenter", openMenu);
    trigger.addEventListener("pointerleave", closeMenu);
    trigger.addEventListener("focusin", openMenu);
    trigger.addEventListener("focusout", (event) => {
      if (!trigger.contains(event.relatedTarget)) closeMenu();
    });
  });
</script>
