---
/**
 * Header.astro — Revenant Edge premium minimalist header
 *
 * Props:
 *   solidFromTop?: boolean  - When true, header renders in solid bg-paper/ink state
 *                             immediately (for non-hero pages: /styleguide, product detail, etc.)
 *                             Default: false (transparent over dark hero, transitions to solid on scroll)
 */
import CartIcon from "./CartIcon.svelte";

interface Props {
  solidFromTop?: boolean;
}

const { solidFromTop = false } = Astro.props;

const collectionLinks = [
  { label: "Shop Children of the Sea", href: "/collections/collection-1-children-of-the-sea" },
  { label: "Shop Demon Slayer", href: "/collections/demon-slayer" },
  { label: "Lookbook", href: "/blogs/lookbook" },
  { label: "Behind the Brand", href: "/about" },
];

const contactLink = { label: "Contact", href: "/contact" };
const drawerLinks = [...collectionLinks, contactLink];
---

<header
  id="site-header"
  class:list={[
    "left-0 right-0 z-50 transition-all",
    solidFromTop ? "relative" : "absolute",
  ]}
  style={`top: ${solidFromTop ? "auto" : "var(--announcement-bar-height, 22px)"}; transition-property: background-color, border-color, color; transition-duration: 280ms; transition-timing-function: cubic-bezier(0.4,0,0.2,1);`}
  data-solid-from-top={solidFromTop ? "true" : "false"}
>
  <div class="mx-auto flex h-16 max-w-none items-center px-4 md:px-6 lg:px-8">

    <div class="flex flex-1 items-center">
      <div class="site-menu" data-site-menu>
        <button
          type="button"
          class="header-menu-button"
          aria-label="Open menu"
          aria-controls="site-menu-drawer"
          aria-expanded="false"
          aria-haspopup="dialog"
          data-site-menu-open
        >
          <span class="sr-only">Open menu</span>
          <span class="header-menu-button__bars" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </button>

        <button
          type="button"
          class="site-menu__overlay"
          data-site-menu-close
          aria-label="Close menu"
          tabindex="-1"
        ></button>

        <aside
          id="site-menu-drawer"
          class="site-menu__drawer"
          role="dialog"
          aria-modal="true"
          aria-label="Menu"
          tabindex="-1"
        >
          <div class="site-menu__inner">
            <div class="site-menu__top">
              <button
                type="button"
                class="site-menu__close"
                data-site-menu-close
                aria-label="Close menu"
              >
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <path d="M4 4l10 10M14 4 4 14" stroke="currentColor" stroke-width="1.6" stroke-linecap="square" />
                </svg>
              </button>
            </div>

            <nav class="site-menu__nav" aria-label="Main menu">
              <ul class="site-menu__list">
                {drawerLinks.map((link) => (
                  <li>
                    <a href={link.href} class="site-menu__link" data-site-menu-link>
                      <span>{link.label}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      </div>
    </div>

    <a
      href="/"
      class="absolute left-1/2 -translate-x-1/2 md:relative md:left-auto md:shrink-0 md:translate-x-0 md:px-4 lg:px-6"
      aria-label="Revenant Edge home"
    >
      <img
        src="/logo-mark-white.png"
        alt="Revenant Edge"
        class="header-logo-white h-[34px] w-auto"
        width="98"
        height="30"
        loading="eager"
        fetchpriority="high"
      />
      <img
        src="/logo-mark-ink.png"
        alt="Revenant Edge"
        class="header-logo-black h-[34px] w-auto"
        width="98"
        height="30"
        loading="eager"
        fetchpriority="high"
      />
    </a>

    <div class="flex flex-1 items-center justify-end">
      <CartIcon client:load />
    </div>
  </div>

  <div class="header-border absolute bottom-0 left-0 right-0 h-px origin-left scale-x-0 transition-all duration-[280ms]" style="background-color: var(--color-line);"></div>
</header>

<style>
  /*
   * Transparent hero state.
   * Header background: transparent; content: paper (white)
   */
  #site-header {
    background-color: transparent;
    color: var(--color-paper);
  }
  #site-header .header-logo-white { display: block; }
  #site-header .header-logo-black { display: none; }
  #site-header .header-border { transform: scaleX(0); }

  /*
   * Solid state for pages without a dark hero.
   */
  #site-header[data-solid-from-top="true"] {
    background-color: var(--color-paper);
    color: var(--color-ink);
  }
  #site-header[data-solid-from-top="true"] .header-logo-white { display: none; }
  #site-header[data-solid-from-top="true"] .header-logo-black { display: block; }
  #site-header[data-solid-from-top="true"] .header-border { transform: scaleX(1); }

  /* Nav link hover: ember underline */
  .header-nav-link {
    position: relative;
    font-size: 10px;
    line-height: 1;
    transition: opacity 180ms;
    white-space: nowrap;
  }

  @media (min-width: 1024px) {
    .header-nav-link {
      font-size: 11px;
    }
  }
  .header-nav-link::after {
    content: "";
    position: absolute;
    bottom: -3px;
    left: 0;
    right: 0;
    height: 1px;
    background-color: var(--color-ember);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .header-nav-link:hover::after {
    transform: scaleX(1);
  }
  .header-nav-link:hover {
    opacity: 0.8;
  }

  .header-menu-button {
    display: grid;
    height: 2.75rem;
    width: 2.75rem;
    place-items: center;
    border: 0;
    background: transparent;
    color: currentColor;
    cursor: pointer;
    font: inherit;
    padding: 0;
    transition: opacity 180ms var(--ease-standard);
  }

  .header-menu-button:hover,
  .header-menu-button:focus-visible {
    opacity: 0.72;
  }

  .header-menu-button__bars {
    display: flex;
    height: 18px;
    width: 24px;
    flex-direction: column;
    justify-content: space-between;
  }

  .header-menu-button__bars span {
    display: block;
    height: 2px;
    width: 100%;
    background: currentColor;
  }

  .site-menu {
    display: flex;
    align-items: center;
  }

  .site-menu__overlay {
    position: fixed;
    inset: 0;
    z-index: 95;
    border: 0;
    background: rgba(0, 0, 0, 0.18);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    cursor: pointer;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 260ms var(--ease-standard),
      visibility 0ms linear 260ms;
  }

  .site-menu__drawer {
    pointer-events: none;
    visibility: hidden;
    position: fixed;
    left: 0;
    top: 0;
    bottom: 0;
    z-index: 100;
    width: 100%;
    max-width: 40rem;
    height: 100vh;
    height: 100dvh;
    background: var(--color-paper);
    color: var(--color-ink);
    overflow: hidden;
    transform: translateX(-110%);
    transition:
      transform 420ms cubic-bezier(0.602, 0.007, 0.374, 0.995),
      visibility 0ms linear 420ms;
  }

  html.site-menu-open .site-menu__overlay {
    pointer-events: auto;
    visibility: visible;
    opacity: 1;
    transition-delay: 0ms, 0ms;
  }

  html.site-menu-open .site-menu__drawer {
    pointer-events: auto;
    visibility: visible;
    transform: translateX(0);
    transition-delay: 0ms, 0ms;
  }

  .site-menu__inner {
    display: flex;
    height: 100%;
    flex-direction: column;
  }

  .site-menu__top {
    display: flex;
    min-height: 4rem;
    align-items: center;
    padding: 0 1.2rem;
  }

  .site-menu__close {
    display: grid;
    height: 2.75rem;
    width: 2.75rem;
    place-items: center;
    border: 0;
    background: transparent;
    color: var(--color-ink);
    cursor: pointer;
    padding: 0;
    transition: opacity 180ms var(--ease-standard);
  }

  .site-menu__close:hover,
  .site-menu__close:focus-visible {
    opacity: 0.6;
  }

  .site-menu__nav {
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 0 1.2rem 2rem;
  }

  .site-menu__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-menu__list > li {
    border-top: 1px solid var(--color-line);
  }

  .site-menu__list > li:last-child {
    border-bottom: 1px solid var(--color-line);
  }

  .site-menu__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1.18rem 0;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    line-height: 1;
    text-decoration: none;
    text-transform: uppercase;
    transition: opacity 180ms var(--ease-standard);
  }

  .site-menu__link:hover,
  .site-menu__link:focus-visible {
    opacity: 0.6;
  }
</style>

<script>
  (() => {
    const root = document.documentElement;
    const menu = document.querySelector("[data-site-menu]");
    const openButton = menu?.querySelector("[data-site-menu-open]");
    const drawer = menu?.querySelector("#site-menu-drawer");
    const OPEN_CLASS = "site-menu-open";

    if (!menu || !openButton || !drawer) return;

    function setOpen(isOpen) {
      root.classList.toggle(OPEN_CLASS, isOpen);
      openButton.setAttribute("aria-expanded", isOpen ? "true" : "false");
      document.body.style.overflow = isOpen ? "hidden" : "";
      if (isOpen) drawer.focus();
    }

    function isOpen() {
      return root.classList.contains(OPEN_CLASS);
    }

    function toggleMenu() {
      setOpen(!isOpen());
    }

    openButton.addEventListener("click", toggleMenu);

    menu.querySelectorAll("[data-site-menu-close], [data-site-menu-link]").forEach((element) => {
      element.addEventListener("click", () => setOpen(false));
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && isOpen()) {
        setOpen(false);
        openButton.focus();
      }
    });

    window.addEventListener("pageshow", () => {
      setOpen(false);
    });
  })();
</script>
