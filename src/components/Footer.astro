---
const year = new Date().getFullYear();
---

<footer class="bg-ink text-paper">
  <!-- ── Main grid ── -->
  <div class="container py-16">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand / wordmark column -->
      <div class="flex flex-col gap-6">
        <a href="/" class="font-display font-bold tracking-tight text-lg text-paper hover:text-ember transition-colors">
          REVENANT EDGE
        </a>
        <p class="font-sans text-xs text-paper/60 leading-relaxed max-w-[220px]">
          Hand-finished garments built to last. No filler. No noise.
        </p>
        <!-- Social row -->
        <div class="flex items-center gap-5 mt-2">
          <!-- Instagram — TODO: replace href with real profile in Phase 4 -->
          <a href="#TODO-instagram" aria-label="Instagram" class="text-paper/50 hover:text-paper transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <!-- TikTok — TODO: replace href with real profile in Phase 4 -->
          <a href="#TODO-tiktok" aria-label="TikTok" class="text-paper/50 hover:text-paper transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.87a8.17 8.17 0 004.78 1.52V7a4.85 4.85 0 01-1.01-.31z"/>
            </svg>
          </a>
          <!-- X / Twitter — TODO: replace href with real profile in Phase 4 -->
          <a href="#TODO-x" aria-label="X (Twitter)" class="text-paper/50 hover:text-paper transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- SHOP column — TODO: replace hrefs with real collection routes in Phase 4 -->
      <div>
        <p class="nav-label text-paper mb-5">Shop</p>
        <ul class="space-y-3">
          <li><a href="#TODO-new-arrivals" class="font-sans text-sm text-paper/70 hover:text-paper transition-colors">New Arrivals</a></li>
          <li><a href="#TODO-shop-all" class="font-sans text-sm text-paper/70 hover:text-paper transition-colors">Shop All</a></li>
          <li><a href="#TODO-hoodies" class="font-sans text-sm text-paper/70 hover:text-paper transition-colors">Hoodies</a></li>
          <li><a href="#TODO-tees" class="font-sans text-sm text-paper/70 hover:text-paper transition-colors">Tees</a></li>
        </ul>
      </div>

      <!-- HELP column — TODO: replace hrefs with real pages in Phase 4 -->
      <div>
        <p class="nav-label text-paper mb-5">Help</p>
        <ul class="space-y-3">
          <li><a href="#TODO-shipping" class="font-sans text-sm text-paper/70 hover:text-paper transition-colors">Shipping</a></li>
          <li><a href="#TODO-returns" class="font-sans text-sm text-paper/70 hover:text-paper transition-colors">Returns</a></li>
          <li><a href="#TODO-size-guide" class="font-sans text-sm text-paper/70 hover:text-paper transition-colors">Size Guide</a></li>
          <li><a href="#TODO-contact" class="font-sans text-sm text-paper/70 hover:text-paper transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- BRAND column — TODO: replace hrefs with real pages in Phase 4 -->
      <div>
        <p class="nav-label text-paper mb-5">Brand</p>
        <ul class="space-y-3">
          <li><a href="#TODO-our-story" class="font-sans text-sm text-paper/70 hover:text-paper transition-colors">Our Story</a></li>
          <li><a href="#TODO-journal" class="font-sans text-sm text-paper/70 hover:text-paper transition-colors">Journal</a></li>
        </ul>
      </div>
    </div>

    <!-- ── Newsletter block ── -->
    <div class="mt-16 border-t border-paper/10 pt-12">
      <div class="max-w-md">
        <p class="nav-label text-paper mb-3">Join the List</p>
        <p class="font-sans text-sm text-paper/60 mb-6">
          Drop alerts, early access, and nothing else.
        </p>
        <!-- TODO Phase 4: wire action to Shopify customer email / Klaviyo list endpoint -->
        <form class="flex gap-0" onsubmit="event.preventDefault()">
          <input
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            autocomplete="email"
            class="flex-1 min-w-0 bg-transparent border border-paper/20 px-4 py-3 font-sans text-sm text-paper placeholder:text-paper/30 focus:outline-none focus:border-paper/60 transition-colors"
          />
          <button
            type="submit"
            class="nav-label shrink-0 bg-paper text-ink px-5 py-3 hover:bg-ember hover:text-paper transition-colors"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- ── Bottom bar ── -->
  <div class="border-t border-paper/10">
    <div class="container py-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <p class="font-sans text-xs text-paper/40">
        &copy; {year} Revenant Edge. All rights reserved.
      </p>
      <nav class="flex items-center gap-6" aria-label="Legal">
        <!-- TODO Phase 4: replace hrefs with real policy pages -->
        <a href="#TODO-privacy" class="font-sans text-xs text-paper/40 hover:text-paper/70 transition-colors">Privacy</a>
        <a href="#TODO-terms" class="font-sans text-xs text-paper/40 hover:text-paper/70 transition-colors">Terms</a>
      </nav>
    </div>
  </div>
</footer>
