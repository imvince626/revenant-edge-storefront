---
const year = new Date().getFullYear();

const shopLinks = [
  ["Children of the Sea", "/collections/collection-1-children-of-the-sea"],
  ["Demon Slayer", "/collections/demon-slayer"],
];

const helpLinks = [
  ["Shipping & Returns", "/pages/returns-exchanges-and-refunds"],
  ["Size Guide", "/pages/size-guide"],
  ["Contact", "/contact"],
  ["Privacy", "/privacy-policy"],
];

const brandLinks = [
  ["Our Story", "/about"],
  ["Lookbook", "/blogs/lookbook"],
  ["Retail", "/retail"],
  ["Terms", "/terms-of-service"],
];

const trustpilotUrl = "https://www.trustpilot.com/review/revenantedge.com";
const trustpilotReviews = [
  {
    name: "Vinny Picone",
    date: "Aug 3, 2025",
    quote: "Sick designs, quick shipping, and quality merchandise.",
  },
  {
    name: "Xiaoyu Clements",
    date: "Nov 24, 2024",
    quote: "The prints are perfect and the artwork is stunning.",
  },
];
---

<footer class="bg-ink text-paper" data-site-footer>
  <!-- ── Main grid ── -->
  <div class="container py-10 md:py-16">
    <section
      id="trustpilot-reviews"
      class="mb-10 border-b border-paper/10 pb-8 md:mb-16 md:pb-12"
      aria-labelledby="trustpilot-reviews-heading"
    >
      <div class="grid gap-6 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] lg:items-start">
        <div>
          <p class="nav-label mb-3 text-paper/70 md:mb-4">Trustpilot</p>
          <h2
            id="trustpilot-reviews-heading"
            class="font-sans text-2xl font-semibold leading-tight text-paper md:text-4xl"
          >
            Reviewed by Revenant Edge customers.
          </h2>
          <a
            href={trustpilotUrl}
            target="_blank"
            rel="noreferrer"
            class="mt-4 inline-flex items-center gap-3 font-sans text-sm font-semibold text-paper/70 transition-colors hover:text-paper md:mt-6"
          >
            <span class="text-[#00b67a]" aria-hidden="true">★★★★★</span>
            <span>3.8 TrustScore from 2 reviews</span>
            <span aria-hidden="true">↗</span>
          </a>
        </div>

        <div class="hidden gap-px bg-paper/10 md:grid md:grid-cols-2">
          {trustpilotReviews.map((review) => (
            <article class="bg-ink p-5">
              <div class="flex items-center justify-between gap-4">
                <h3 class="font-sans text-sm font-semibold text-paper">{review.name}</h3>
                <span class="font-sans text-xs font-semibold text-[#00b67a]" aria-label="5 out of 5 stars">
                  ★★★★★
                </span>
              </div>
              <p class="mt-1 font-sans text-xs font-semibold text-paper/40">{review.date}</p>
              <p class="mt-5 font-sans text-sm font-semibold leading-relaxed text-paper/70">
                "{review.quote}"
              </p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <div class="grid grid-cols-2 gap-x-8 gap-y-9 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand / wordmark column -->
      <div class="col-span-2 lg:col-span-1">
        <a href="/" class="inline-flex transition-opacity hover:opacity-70" aria-label="Revenant Edge home">
          <img
            src="/logo-mark-white.png"
            alt="Revenant Edge"
            width="126"
            height="39"
            loading="lazy"
            class="h-auto w-[8.5rem]"
          />
        </a>
      </div>

      <div>
        <p class="nav-label mb-3 text-paper">Shop</p>
        <ul class="space-y-2">
          {shopLinks.map(([label, href]) => (
            <li><a href={href} class="font-sans text-sm text-paper/70 hover:text-paper transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <p class="nav-label mb-3 text-paper">Help</p>
        <ul class="space-y-2">
          {helpLinks.map(([label, href]) => (
            <li><a href={href} class="font-sans text-sm text-paper/70 hover:text-paper transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <p class="nav-label mb-3 text-paper">Brand</p>
        <ul class="space-y-2">
          {brandLinks.map(([label, href]) => (
            <li><a href={href} class="font-sans text-sm text-paper/70 hover:text-paper transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- ── Newsletter block ── -->
    <div class="mt-10 border-t border-paper/10 pt-8 md:mt-16 md:pt-12">
      <div class="max-w-md">
        <p class="nav-label mb-3 text-paper">Join the List</p>
        <p class="mb-4 font-sans text-sm text-paper/60 md:mb-6">
          Drop alerts, early access, and nothing else.
        </p>
        <form class="flex gap-0" data-newsletter-form>
          <input
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            autocomplete="email"
            class="flex-1 min-w-0 bg-transparent border border-paper/20 px-4 py-3 font-sans text-sm text-paper placeholder:text-paper/30 focus:outline-none focus:border-paper/60 transition-colors"
          />
          <button
            type="submit"
            class="nav-label shrink-0 bg-paper text-ink px-5 py-3 hover:bg-ember hover:text-paper transition-colors"
          >
            Subscribe
          </button>
        </form>
        <p class="mt-3 min-h-5 font-sans text-xs text-paper/60" aria-live="polite" data-newsletter-status></p>
      </div>
    </div>
  </div>

  <!-- ── Bottom bar ── -->
  <div class="border-t border-paper/10">
    <div class="container flex flex-col gap-3 py-4 sm:flex-row sm:items-center sm:justify-between md:py-6">
      <p class="font-sans text-xs text-paper/40">
        &copy; {year} Revenant Edge. All rights reserved.
      </p>
      <nav class="flex items-center gap-6" aria-label="Legal">
        <a href="/privacy-policy" class="font-sans text-xs text-paper/40 hover:text-paper/70 transition-colors">Privacy</a>
        <a href="/terms-of-service" class="font-sans text-xs text-paper/40 hover:text-paper/70 transition-colors">Terms</a>
      </nav>
    </div>
  </div>
</footer>

<script>
  const newsletterForms = document.querySelectorAll("[data-newsletter-form]");

  newsletterForms.forEach((form) => {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const emailInput = form.querySelector("input[name='email']");
      const status = form.parentElement?.querySelector("[data-newsletter-status]");
      const submit = form.querySelector("button[type='submit']");
      const email = emailInput?.value?.trim();

      if (!email) return;

      submit?.setAttribute("disabled", "true");
      if (status) status.textContent = "Signing you up...";

      try {
        const response = await fetch("/api/newsletter", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });
        const result = await response.json();

        if (!response.ok || !result.ok) {
          throw new Error(result.message || "Signup failed");
        }

        form.reset();
        if (status) status.textContent = "You're on the list.";
      } catch (_) {
        if (status) status.textContent = "We could not sign you up. Email hello@revenantedge.com.";
      } finally {
        submit?.removeAttribute("disabled");
      }
    });
  });
</script>
