---
const year = new Date().getFullYear();

const helpLinks = [
  ["Contact Us", "/contact"],
  ["Shipping & Returns", "/pages/returns-exchanges-and-refunds"],
  ["Size Guide", "/pages/size-guide"],
  ["Terms of Service", "/terms-of-service"],
  ["Privacy Policy", "/privacy-policy"],
];
---

<footer class="border-t border-line bg-paper text-ink" data-site-footer>
  <div class="container min-h-[24rem] py-8 md:min-h-[26rem] md:py-10">
    <div class="grid gap-14 md:grid-cols-[minmax(0,34rem)_minmax(12rem,18rem)] md:justify-between">
      <section aria-labelledby="footer-newsletter-heading">
        <a href="/" class="mb-7 inline-flex transition-opacity hover:opacity-70" aria-label="Revenant Edge home">
          <img
            src="/logo-mark-ink.png"
            alt="Revenant Edge"
            width="126"
            height="39"
            loading="lazy"
            class="h-auto w-[8rem]"
          />
        </a>
        <p id="footer-newsletter-heading" class="nav-label mb-5 text-ink">
          Subscribe to our newsletter
        </p>
        <form class="flex max-w-[35rem] gap-0" data-newsletter-form>
          <input
            type="email"
            name="email"
            placeholder="Email address"
            required
            autocomplete="email"
            class="min-w-0 flex-1 border border-line bg-paper px-4 py-4 font-sans text-sm text-ink placeholder:text-muted/70 transition-colors focus:border-ink focus:outline-none"
          />
          <button
            type="submit"
            class="nav-label shrink-0 border border-l-0 border-line bg-paper px-5 py-4 text-ink transition-colors hover:bg-ink hover:text-paper"
          >
            Subscribe
          </button>
        </form>
        <p class="mt-4 font-sans text-sm font-semibold text-muted">
          By subscribing, you agree to our <a href="/privacy-policy" class="underline underline-offset-2 hover:text-ink">Privacy Policy</a>.
        </p>
        <p class="mt-2 min-h-5 font-sans text-xs text-muted" aria-live="polite" data-newsletter-status></p>
      </section>

      <nav aria-labelledby="footer-help-heading">
        <p id="footer-help-heading" class="nav-label mb-5 text-ink">Help</p>
        <ul class="space-y-2">
          {helpLinks.map(([label, href]) => (
            <li>
              <a href={href} class="font-sans text-sm font-semibold text-ink transition-opacity hover:opacity-60">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <p class="mt-20 font-sans text-xs font-semibold text-muted/35 md:mt-28">
      &copy; {year} Revenant Edge.
    </p>
  </div>
</footer>

<script>
  const newsletterForms = document.querySelectorAll("[data-newsletter-form]");

  newsletterForms.forEach((form) => {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const emailInput = form.querySelector("input[name='email']");
      const status = form.parentElement?.querySelector("[data-newsletter-status]");
      const submit = form.querySelector("button[type='submit']");
      const email = emailInput?.value?.trim();

      if (!email) return;

      submit?.setAttribute("disabled", "true");
      if (status) status.textContent = "Signing you up...";

      try {
        const response = await fetch("/api/newsletter", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });
        const result = await response.json();

        if (!response.ok || !result.ok) {
          throw new Error(result.message || "Signup failed");
        }

        form.reset();
        if (status) status.textContent = "You're on the list.";
      } catch (_) {
        if (status) status.textContent = "We could not sign you up. Email hello@revenantedge.com.";
      } finally {
        submit?.removeAttribute("disabled");
      }
    });
  });
</script>
