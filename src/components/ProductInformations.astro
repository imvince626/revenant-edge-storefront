---
import type { z } from "zod";
import type { MoneyV2Result } from "../utils/schemas";
import Money from "./Money.svelte";

export interface Props {
  price?: z.infer<typeof MoneyV2Result>;
  quote?: string | null;
  title: string;
}
const { price, quote, title } = Astro.props as Props;
---

<div>
  <div class="flex items-start justify-between gap-6">
    <div class="min-w-0">
      <h1 class="font-sans text-[13px] font-semibold leading-snug text-ink">
        {title}
      </h1>

      {quote && (
        <p class="mt-4 font-sans text-[13px] leading-snug text-muted">
          {quote}
        </p>
      )}
    </div>

    {price && (
      <p class="shrink-0 font-sans text-[13px] font-semibold text-ink">
        <Money price={price} showCurrency={false} client:load />
      </p>
    )}
  </div>
  <div class="mt-5 flex items-center gap-2 text-sm text-ink" aria-label="Product rating">
    <span class="tracking-[0.08em]" aria-hidden="true">★★★★★</span>
    <a href="#trustpilot-reviews" class="font-sans text-xs text-muted underline underline-offset-2">
      2 Reviews
    </a>
  </div>
</div>
