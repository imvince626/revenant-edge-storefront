---
import type { z } from "zod";
import type { MoneyV2Result } from "../utils/schemas";
import Money from "./Money.svelte";

export interface Props {
  price?: z.infer<typeof MoneyV2Result>;
  title: string;
}
const { price, title } = Astro.props as Props;
---

<div class="border-b border-line pb-5">
  <p class="nav-label mb-3 text-muted">Revenant Edge</p>
  <h1 class="font-display text-[1.75rem] font-bold uppercase leading-[1.05] text-ink md:text-[2.15rem]">
    {title}
  </h1>

  {price && (
    <p class="mt-4 font-sans text-sm font-medium text-ink">
      <Money price={price} showCurrency={false} client:load />
    </p>
  )}
</div>
