---
import type { z } from "zod";
import type { MoneyV2Result } from "../utils/schemas";
import Money from "./Money.svelte";

export interface Props {
  price?: z.infer<typeof MoneyV2Result>;
  title: string;
}
const { price, title } = Astro.props as Props;
---

<div>
  <p class="nav-label mb-4 hidden text-muted lg:block">App Exclusive</p>
  <div class="flex items-start justify-between gap-6">
    <h1 class="font-sans text-2xl font-semibold leading-snug text-ink lg:text-[1rem]">
      {title}
    </h1>

    {price && (
      <p class="shrink-0 font-sans text-2xl font-semibold text-ink lg:text-sm">
        <Money price={price} showCurrency={false} client:load />
      </p>
    )}
  </div>
</div>
