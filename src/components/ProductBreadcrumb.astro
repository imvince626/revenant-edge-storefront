---
export interface Props {
  title: string;
}
const { title } = Astro.props as Props;
---

<nav aria-label="Breadcrumb">
  <ol role="list" class="flex items-center gap-2">
    <li>
      <a href="/" class="nav-label text-muted transition-colors hover:text-ink">
        Home
      </a>
    </li>
    <li class="text-muted" aria-hidden="true">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="currentColor"
        class="h-3 w-3"
      >
        <path
          fill-rule="evenodd"
          d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
          clip-rule="evenodd"
        ></path>
      </svg>
    </li>
    <li>
      <span class="nav-label text-ink truncate max-w-[200px] sm:max-w-none">
        {title}
      </span>
    </li>
  </ol>
</nav>
