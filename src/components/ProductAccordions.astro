---
const accordions = [
  {
    title: "Shipping",
    content:
      "Free standard shipping on orders over $75. Orders ship within 1 to 3 business days via USPS or UPS. Expedited options available at checkout.",
  },
  {
    title: "Care Instructions",
    content:
      "Machine wash cold, inside out. Tumble dry low or hang dry. Do not bleach. Iron on reverse only. These garments are hand-finished, gentle handling keeps the print sharp.",
  },
  {
    title: "Returns",
    content:
      "Unworn, unwashed items may be returned within 30 days of delivery. Final sale items are not eligible for return. Start a return at revenantedge.com/returns.",
  },
];
---

<div class="border-t border-line">
  {accordions.map((accordion, index) => (
    <details
      class:list={[
        "group",
        { "border-b border-line": index === accordions.length - 1 },
      ]}
    >
      <summary class="flex cursor-pointer items-center justify-between border-b border-line py-4 px-0 font-sans text-sm font-medium text-ink group-open:border-transparent">
        <span class="nav-label">{accordion.title}</span>
        <span class="transition-transform duration-[280ms] group-open:rotate-180 text-muted">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="h-4 w-4"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 8.25l-7.5 7.5-7.5-7.5"
            />
          </svg>
        </span>
      </summary>
      <div class="pb-4 text-sm leading-relaxed text-muted font-sans border-b border-line">
        {accordion.content}
      </div>
    </details>
  ))}
</div>
