---
const accordions = [
  {
    title: "Details",
    content:
      "Hand-finished graphic apparel produced in limited runs. Each piece is cut for daily wear with a soft feel and a durable print.",
  },
  {
    title: "FAQ",
    content:
      "Need help with sizing, fit, or care? Contact the team before the drop sells through.",
  },
];
---

<div class="border-t border-line">
  {accordions.map((accordion, index) => (
    <details
      class:list={[
        "group bg-paper",
        { "border-b border-line": index === accordions.length - 1 },
      ]}
    >
      <summary class="flex cursor-pointer list-none items-center justify-between border-b border-line px-0 py-4 font-sans text-sm font-semibold text-ink group-open:border-transparent [&::-webkit-details-marker]:hidden">
        <span>{accordion.title}</span>
        <span class="grid h-5 w-5 place-items-center text-lg leading-none text-muted transition-transform duration-[220ms] group-open:rotate-45" aria-hidden="true">
          +
        </span>
      </summary>
      <div class="border-b border-line pb-5 pr-8 font-sans text-sm leading-relaxed text-muted">
        {accordion.content}
      </div>
    </details>
  ))}
</div>
