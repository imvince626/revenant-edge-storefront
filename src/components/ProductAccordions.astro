---
const accordions = [
  {
    title: "Product Details",
    content:
      "Hand-finished graphic apparel produced in limited runs. Each piece is cut for daily wear with a soft feel and a durable print.",
  },
  {
    title: "Size and Fit",
    content:
      "Tees fit true to size. Hoodies are relaxed with room through the body. Size down for a closer fit.",
  },
  {
    title: "Composition and Care",
    content:
      "Machine wash cold, inside out. Tumble dry low or hang dry. Do not bleach. Iron on reverse only.",
  },
  {
    title: "Shipping and Returns",
    content:
      "Free standard shipping on all orders over $100. Unworn, unwashed items may be returned within 30 days of delivery.",
  },
];
---

<div class="border-t border-line">
  {accordions.map((accordion, index) => (
    <details
      class:list={[
        "group",
        { "border-b border-line": index === accordions.length - 1 },
      ]}
    >
      <summary class="flex cursor-pointer items-center justify-between border-b border-line py-4 px-0 font-sans text-sm font-semibold text-ink group-open:border-transparent">
        <span>{accordion.title}</span>
        <span class="transition-transform duration-[280ms] group-open:rotate-180 text-muted">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="h-4 w-4"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 8.25l-7.5 7.5-7.5-7.5"
            />
          </svg>
        </span>
      </summary>
      <div class="border-b border-line pb-4 font-sans text-sm leading-relaxed text-muted">
        {accordion.content}
      </div>
    </details>
  ))}
</div>
