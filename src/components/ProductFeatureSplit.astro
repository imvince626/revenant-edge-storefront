---
import { productLifestyleImages } from "../utils/product-media";

export interface Props {
  productHandle: string;
}

const { productHandle } = Astro.props as Props;

const lifestyleImages = productLifestyleImages(productHandle);
const fitMedia = lifestyleImages[0] ?? null;
const fallbackVideo = {
  src: productHandle.includes("king-of-hell") || productHandle.includes("drums-of-liberation")
    ? "/videos/demon-slayer-home.mp4"
    : "/hero-loop.mp4",
  poster: "/hero-loop-poster.jpg",
};

function imageUrlWithWidth(url: string, width: number) {
  if (url.startsWith("/")) return url;
  return `${url}${url.includes("?") ? "&" : "?"}width=${width}`;
}

const specs = [
  ["100% Cotton", "Premium heavyweight Revenant Edge blank"],
  ["Heavy Print", "Screenprinted graphics on the front and back"],
  ["Made in USA", "Made in the United States and fulfilled from Los Angeles"],
  ["Oversized Fit", "Relaxed body with a structured streetwear drape"],
];
---

<section id="product-quality" class="border-t border-line bg-paper text-ink">
  <div class="grid lg:grid-cols-[0.92fr_1.08fr]">
    <div class="flex min-h-[30rem] items-center px-6 py-14 md:px-12 md:py-18 lg:min-h-[42rem] lg:px-16">
      <div class="max-w-xl">
        <h2 class="font-sans text-4xl font-semibold leading-[0.95] text-ink md:text-6xl">
          Made for the blank, the print, and the fit.
        </h2>
        <p class="mt-7 font-sans text-base font-semibold leading-relaxed text-muted md:text-lg">
          Every Revenant Edge piece is built around the same essentials: heavyweight cotton, heavy screenprinted graphics, and an oversized fit that holds shape.
        </p>

        <div class="mt-10 grid grid-cols-2 border-y border-line md:grid-cols-4">
          {specs.map(([title, body]) => (
            <div class="border-line py-5 pr-4 md:border-r md:pr-5 md:last:border-r-0">
              <h3 class="font-sans text-sm font-semibold uppercase leading-tight text-ink">
                {title}
              </h3>
              <p class="mt-3 font-sans text-xs font-semibold leading-relaxed text-muted">
                {body}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="min-h-[30rem] overflow-hidden bg-ink lg:min-h-[42rem]">
      {fitMedia ? (
        <img
          src={imageUrlWithWidth(fitMedia.url, 1600)}
          alt={fitMedia.altText}
          width={fitMedia.width}
          height={fitMedia.height}
          loading="lazy"
          class="h-full min-h-[30rem] w-full object-cover lg:min-h-[42rem]"
          sizes="(min-width: 1024px) 54vw, 100vw"
        />
      ) : (
        <video
          class="h-full min-h-[30rem] w-full object-cover lg:min-h-[42rem]"
          autoplay
          muted
          loop
          playsinline
          poster={fallbackVideo.poster}
        >
          <source src={fallbackVideo.src} type="video/mp4" />
        </video>
      )}
    </div>
  </div>
</section>
