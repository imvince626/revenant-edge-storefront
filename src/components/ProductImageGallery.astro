---
import { z } from "zod";
import { ImageResult } from "../utils/schemas";
import {
  isLifestyleImage,
  productLifestyleImages,
} from "../utils/product-media";

const ImagesResult = z.object({
  nodes: z.array(ImageResult),
});

type GalleryImage = NonNullable<z.infer<typeof ImageResult>> & {
  display?: "contain" | "cover";
};

export interface Props {
  images: z.infer<typeof ImagesResult>;
  productHandle?: string;
}
const { images, productHandle } = Astro.props as Props;

const PRODUCT_GALLERY_IMAGE_OVERRIDES: Record<string, z.infer<typeof ImageResult>[]> = {
  "light-within-the-dark-hoodie-black": [
    {
      url: "/images/product-overrides/light-within-the-dark-hoodie-back-white.png",
      width: 1080,
      height: 1080,
      altText: "Light Within The Dark Hoodie Black Back",
    },
    {
      url: "/images/product-overrides/light-within-the-dark-hoodie-front-white.png",
      width: 1080,
      height: 1080,
      altText: "Light Within The Dark Hoodie Black Front",
    },
  ],
};

function imageUrlWithWidth(url: string, width: number) {
  if (url.startsWith("/")) return url;
  return `${url}${url.includes("?") ? "&" : "?"}width=${width}`;
}

function imageSourceKey(url: string) {
  const match = decodeURIComponent(url)
    .toLowerCase()
    .match(/(?:tre\d+|img[_-]?\d+)/);
  return match ? match[0].replace("_", "-") : null;
}

function mergeImages(shopifyImages: GalleryImage[], localImages: GalleryImage[]) {
  const localKeys = new Set(localImages.map((image) => imageSourceKey(image.url)).filter(Boolean));
  const seen = new Set<string>();

  const productImages = shopifyImages
    .filter((image) => {
      const key = imageSourceKey(image.url);
      return !key || !localKeys.has(key);
    })
    .filter((image) => {
      const key = image.url;
      if (seen.has(key)) return false;
      seen.add(key);
      return true;
    });

  return [
    ...productImages.slice(0, 2),
    ...localImages,
    ...productImages.slice(2),
  ];
}

const shopifyImages = images.nodes.filter(Boolean) as GalleryImage[];
const lifestyleImages = productLifestyleImages(productHandle);
const allImages = productHandle && PRODUCT_GALLERY_IMAGE_OVERRIDES[productHandle]
  ? PRODUCT_GALLERY_IMAGE_OVERRIDES[productHandle]
  : mergeImages(shopifyImages, lifestyleImages);
const galleryImages = allImages.length > 0 ? allImages : [null];
const heroImage = galleryImages[0];
const fullscreenImageUrl = heroImage?.url
  ? imageUrlWithWidth(heroImage.url, 1800)
  : "";
const galleryPayload = galleryImages.filter(Boolean).map((image) => ({
  src: imageUrlWithWidth(image.url, 1800),
  alt: image.altText ?? "Revenant Edge product image",
  width: image.width,
  height: image.height,
  display: isLifestyleImage(image) ? "cover" : "contain",
}));
---

<div
  class="relative h-[clamp(500px,135vw,620px)] overflow-hidden bg-paper md:h-[clamp(620px,82vw,820px)] lg:h-screen"
  data-product-gallery
  data-product-gallery-images={JSON.stringify(galleryPayload)}
>
  <div
    class="absolute bottom-5 left-4 z-10 bg-paper px-3 py-2 font-sans text-sm font-semibold leading-none text-muted md:bottom-8 md:left-8 md:px-4 md:py-3 md:text-lg lg:bottom-auto lg:left-4 lg:top-4 lg:px-3 lg:py-2 lg:text-xs lg:text-ink"
    data-product-gallery-count
  >
    1 / {galleryPayload.length || 1}
  </div>
  <button
    class="absolute bottom-5 right-4 z-10 grid h-8 w-8 place-items-center text-ink transition-opacity hover:opacity-60 md:bottom-8 md:right-8"
    type="button"
    aria-label="Open product image fullscreen"
    data-product-fullscreen-open
  >
    <span class="absolute right-1 top-1 h-2 w-2 border-r border-t border-ink"></span>
    <span class="absolute bottom-1 left-1 h-2 w-2 border-b border-l border-ink"></span>
  </button>

  <button
    class="absolute left-3 top-1/2 z-10 grid h-10 w-10 -translate-y-1/2 place-items-center bg-paper/85 font-sans text-3xl leading-none text-ink transition-opacity hover:opacity-60 disabled:hidden md:left-8"
    type="button"
    aria-label="Previous product image"
    data-product-gallery-prev
    disabled={galleryPayload.length <= 1}
  >
    ‹
  </button>
  <button
    class="absolute right-3 top-1/2 z-10 grid h-10 w-10 -translate-y-1/2 place-items-center bg-paper/85 font-sans text-3xl leading-none text-ink transition-opacity hover:opacity-60 disabled:hidden md:right-8"
    type="button"
    aria-label="Next product image"
    data-product-gallery-next
    disabled={galleryPayload.length <= 1}
  >
    ›
  </button>

  <div
    class="no-scrollbar flex h-full snap-x snap-mandatory overflow-x-auto scroll-smooth"
    data-product-gallery-track
    tabindex="0"
    aria-label="Product images"
  >
    {galleryPayload.map((image, index) => (
      <figure
        class="relative h-full w-full shrink-0 snap-center"
        data-product-gallery-slide
      >
        <img
          src={image.src}
          alt={image.alt}
          width={image.width}
          height={image.height}
          class:list={[
            "h-full w-full object-center p-0",
            image.display === "cover"
              ? "object-cover"
              : "scale-100 object-contain md:scale-[1.18] lg:scale-[1.08]",
          ]}
          sizes="(min-width: 1024px) 50vw, 100vw"
          loading={index === 0 ? "eager" : "lazy"}
        />
      </figure>
    ))}
  </div>
</div>

{fullscreenImageUrl && (
  <div
    class="fixed inset-0 z-[120] hidden bg-paper text-ink"
    data-product-fullscreen
    aria-hidden="true"
  >
    <button
      class="absolute right-5 top-5 z-10 grid h-11 w-11 place-items-center text-ink transition-opacity hover:opacity-60"
      type="button"
      aria-label="Close product image fullscreen"
      data-product-fullscreen-close
    >
      <span class="absolute h-px w-7 rotate-45 bg-ink"></span>
      <span class="absolute h-px w-7 -rotate-45 bg-ink"></span>
    </button>
    <div class="flex h-full w-full items-center justify-center bg-paper p-4 md:p-8">
      <img
        src={fullscreenImageUrl}
        alt={heroImage?.altText ?? "Product image"}
        width={heroImage?.width}
        height={heroImage?.height}
        class="max-h-full max-w-full object-contain"
        loading="eager"
        data-product-fullscreen-image
      />
    </div>
  </div>
)}

<script>
  const gallery = document.querySelector("[data-product-gallery]");
  const galleryTrack = document.querySelector("[data-product-gallery-track]");
  /** @type {HTMLElement[]} */
  const gallerySlides = Array.from(document.querySelectorAll("[data-product-gallery-slide]"));
  const galleryCount = document.querySelector("[data-product-gallery-count]");
  const previousButton = document.querySelector("[data-product-gallery-prev]");
  const nextButton = document.querySelector("[data-product-gallery-next]");
  const fullscreen = document.querySelector("[data-product-fullscreen]");
  const fullscreenImage = document.querySelector("[data-product-fullscreen-image]");
  const openButton = document.querySelector("[data-product-fullscreen-open]");
  const closeButton = document.querySelector("[data-product-fullscreen-close]");
  const galleryImages = JSON.parse(gallery?.getAttribute("data-product-gallery-images") ?? "[]");
  let galleryIndex = 0;
  let scrollFrame = 0;

  function updateGalleryMeta() {
    const current = galleryImages[galleryIndex];

    if (galleryCount && galleryImages.length > 0) {
      galleryCount.textContent = `${galleryIndex + 1} / ${galleryImages.length}`;
    }

    if (fullscreenImage && current) {
      fullscreenImage.setAttribute("src", current.src);
      fullscreenImage.setAttribute("alt", current.alt);
      fullscreenImage.setAttribute("width", current.width);
      fullscreenImage.setAttribute("height", current.height);
    }
  }

  function scrollToGalleryImage(index) {
    if (!galleryTrack || gallerySlides.length === 0) return;
    galleryIndex = (index + galleryImages.length) % galleryImages.length;
    galleryTrack.scrollTo({
      left: gallerySlides[galleryIndex].offsetLeft,
      behavior: "smooth",
    });
    updateGalleryMeta();
  }

  function syncGalleryIndexFromScroll() {
    if (!galleryTrack || gallerySlides.length === 0) return;

    window.cancelAnimationFrame(scrollFrame);
    scrollFrame = window.requestAnimationFrame(() => {
      const trackCenter = galleryTrack.scrollLeft + galleryTrack.clientWidth / 2;
      let closestIndex = 0;
      let closestDistance = Number.POSITIVE_INFINITY;

      gallerySlides.forEach((slide, index) => {
        const slideCenter = slide.offsetLeft + slide.clientWidth / 2;
        const distance = Math.abs(trackCenter - slideCenter);
        if (distance < closestDistance) {
          closestIndex = index;
          closestDistance = distance;
        }
      });

      if (closestIndex !== galleryIndex) {
        galleryIndex = closestIndex;
        updateGalleryMeta();
      }
    });
  }

  previousButton?.addEventListener("click", () => scrollToGalleryImage(galleryIndex - 1));
  nextButton?.addEventListener("click", () => scrollToGalleryImage(galleryIndex + 1));
  galleryTrack?.addEventListener("scroll", syncGalleryIndexFromScroll, { passive: true });

  function openFullscreen() {
    if (!fullscreen) return;
    fullscreen.classList.remove("hidden");
    fullscreen.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    closeButton?.focus();
  }

  function closeFullscreen() {
    if (!fullscreen) return;
    fullscreen.classList.add("hidden");
    fullscreen.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    openButton?.focus();
  }

  openButton?.addEventListener("click", openFullscreen);
  closeButton?.addEventListener("click", closeFullscreen);
  fullscreen?.addEventListener("click", (event) => {
    if (event.target === fullscreen) closeFullscreen();
  });
  document.addEventListener("keydown", (event) => {
    if (event.key === "ArrowLeft") scrollToGalleryImage(galleryIndex - 1);
    if (event.key === "ArrowRight") scrollToGalleryImage(galleryIndex + 1);
    if (event.key === "Escape" && fullscreen && !fullscreen.classList.contains("hidden")) {
      closeFullscreen();
    }
  });
</script>
