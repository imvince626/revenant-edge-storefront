---
import { z } from "zod";
import { ImageResult } from "../utils/schemas";
import ShopifyImage from "./ShopifyImage.svelte";

const ImagesResult = z.object({
  nodes: z.array(ImageResult),
});

export interface Props {
  images: z.infer<typeof ImagesResult>;
}
const { images } = Astro.props as Props;

const allImages = images.nodes.filter(Boolean);
const galleryImages = allImages.length > 0 ? allImages : [null];
---

<div class="grid grid-cols-1 gap-1 md:grid-cols-2">
  {galleryImages.map((image, index) => (
    <div class:list={["bg-surface aspect-[3/4] w-full overflow-hidden", index === 0 && "md:col-span-2 md:aspect-[4/5] lg:col-span-1 lg:aspect-[3/4]"]}>
      <ShopifyImage
        classList="h-full w-full object-cover"
        loading={index === 0 ? "eager" : "lazy"}
        image={image}
        sizes={index === 0
          ? "(min-width: 1400px) 520px, (min-width: 1024px) 50vw, 100vw"
          : "(min-width: 1024px) 25vw, (min-width: 768px) 50vw, 100vw"}
      />
    </div>
  ))}
</div>
