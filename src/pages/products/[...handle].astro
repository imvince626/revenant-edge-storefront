---
import { getProductByHandle } from "./../../utils/shopify";
import { setCache } from "../../utils/cache";
import { gmcId } from "../../utils/analytics";
import { isCollection2ProductHandle } from "../../utils/collections";

import BaseLayout from "../../layouts/BaseLayout.astro";
import NotFoundLayout from "../../layouts/NotFoundLayout.astro";
import AddToCartForm from "../../components/AddToCartForm.svelte";
import ProductImageGallery from "../../components/ProductImageGallery.astro";
import ProductInformations from "../../components/ProductInformations.astro";
import ProductFeatureSplit from "../../components/ProductFeatureSplit.astro";
import ProductRecommendations from "../../components/ProductRecommendations.astro";
import TrustpilotReviews from "../../components/TrustpilotReviews.astro";

const { handle } = Astro.params;
if (handle && /-white$/i.test(handle)) {
  return Astro.redirect(`/products/${handle.replace(/-white$/i, "-black")}`, 302);
}

const headers = Astro.request.headers;
const ip = headers.get("x-vercel-forwarded-for") || Astro.clientAddress;
const product = await getProductByHandle({ handle: handle || "", buyerIP: ip });

if (!product) {
  Astro.response.status = 404;
}

const firstVariant = product?.variants.nodes[0];
const allVariants = product?.variants.nodes ?? [];
setCache.short(Astro);

const colorSwatches: Record<string, string> = {
  black: "#0A0A0A",
  white: "#FFFFFF",
  cobalt: "#2747B8",
  storm: "#777D88",
  mushroom: "#B9AC9B",
  ash: "#D3D3D3",
  cream: "#E8E1D2",
};
function inferColor(input = "") {
  const source = input.toLowerCase();
  const color = Object.keys(colorSwatches).find((name) => {
    const pattern = new RegExp(`(^|[^a-z])${name}([^a-z]|$)`, "i");
    return pattern.test(source);
  });

  return color ? color[0].toUpperCase() + color.slice(1) : "Black";
}

const inferredColor = product
  ? inferColor([
      product.title,
      product.handle,
      product.featuredImage?.altText,
      product.featuredImage?.url,
    ].filter(Boolean).join(" "))
  : "Black";

const formatTitleCase = (value: string) =>
  value
    .split(/[-_\s]+/)
    .filter(Boolean)
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
    .join(" ");

const productTitleForMeta = product
  ? (() => {
      const slashParts = product.title.split(/\s*\/\s*/).filter(Boolean);
      if (slashParts.length > 1) {
        return slashParts.join(" - ");
      }

      const colorFromHandle = product.handle.match(
        /-(black|white|cream|grey|gray|navy|red|blue|green|purple|brown)$/i,
      )?.[1];

      return colorFromHandle
        ? `${product.title} - ${formatTitleCase(colorFromHandle)}`
        : product.title;
    })()
  : "";

// ── JSON-LD + view_item data (computed server-side, product is known to exist here) ──
const pdpProduct = product
  ? {
      id: product.id,
      title: product.title,
      variants: product.variants,
      featuredImage: product.featuredImage,
    }
  : null;
const pdpFirstVariant = firstVariant ?? null;

// JSON-LD Product schema for Google Shopping / rich results (SSR only)
const jsonLd = product && firstVariant
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      name: product.title,
      image: product.featuredImage?.url ?? product.images?.nodes?.[0]?.url ?? "",
      description: "",  // No description field in Storefront API result; enrich if added later
      brand: {
        "@type": "Brand",
        name: "Revenant Edge",
      },
      sku: gmcId(product.id, firstVariant.id),
      mpn: gmcId(product.id, firstVariant.id),
      productID: gmcId(product.id, firstVariant.id),
      offers: {
        "@type": "Offer",
        url: `https://revenantedge.com/products/${product.handle}`,
        priceCurrency: "USD",
        price: firstVariant.price?.amount ?? "0",
        availability: firstVariant.availableForSale
          ? "https://schema.org/InStock"
          : "https://schema.org/OutOfStock",
      },
    })
  : null;

// Serialise minimal product/variant data for the client-side view_item call
const analyticsProduct = pdpProduct ? JSON.stringify(pdpProduct) : "null";
const analyticsVariant = pdpFirstVariant ? JSON.stringify(pdpFirstVariant) : "null";
const productQuoteOverrides: Record<string, { label: string; quote: string }> = {
  "children-of-the-sea-tee-black": {
    label: "Whitebeard",
    quote: "\"The One Piece is real!\"",
  },
  "drums-of-liberation-tee-black": {
    label: "Luffy",
    quote: "\"I'm gonna be King of the Pirates!\"",
  },
  "empty-throne-tee-black": {
    label: "Doflamingo",
    quote: "\"Whoever wins this war becomes justice!\"",
  },
  "king-of-hell-tee-black": {
    label: "Zoro",
    quote: "\"Nothing happened.\"",
  },
  "breathe-fight-rise-tee-black": {
    label: "Tanjiro",
    quote: "\"I can do it.\"",
  },
  "fear-nothing-tee-black": {
    label: "Inosuke",
    quote: "\"I'm the King of the Mountains!\"",
  },
  "light-within-the-dark-hoodie-black": {
    label: "Nezuko",
    quote: "\"I will never hurt them.\"",
  },
  "light-within-the-dark-tee-black": {
    label: "Nezuko",
    quote: "\"I will never hurt them.\"",
  },
  "no-regrets-tee-black": {
    label: "Rengoku",
    quote: "\"Live with your head held high.\"",
  },
  "set-your-heart-ablaze-tee-black": {
    label: "Rengoku",
    quote: "\"Set your heart ablaze.\"",
  },
  "the-fear-that-strikes-back-tee-black": {
    label: "Tanjiro",
    quote: "\"Don't run away!\"",
  },
};
const productQuote = product ? productQuoteOverrides[product.handle] ?? null : null;
const fitLabel = product?.title.toLowerCase().includes("hoodie")
  ? "Oversized Pullover Hoodie"
  : "Oversized Graphic Tee";
const isCollection2Product = product ? isCollection2ProductHandle(product.handle) : false;
const recommendationCollection = isCollection2Product
  ? {
      handle: "demon-slayer",
      href: "/collections/demon-slayer",
      heading: "More Collection 2",
      group: "collection-2" as const,
      ctaLabel: "Shop Collection 2",
    }
  : {
      handle: "collection-1-children-of-the-sea",
      href: "/collections/collection-1-children-of-the-sea",
      heading: "More Collection 1",
      group: "collection-1" as const,
      ctaLabel: "Shop Collection 1",
    };
---

{
  !product ? (
    <NotFoundLayout title="Product not found" message="Product not found" />
  ) : (
    <BaseLayout title={`${productTitleForMeta} | Revenant Edge`} solidHeader={true}>
      <!-- JSON-LD Product schema (SSR, for Google Shopping) -->
      {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

      <section class="border-t border-line px-0">
        <div
          class="mx-auto grid max-w-[1920px] grid-cols-1 lg:grid-cols-2"
        >
          <div class="min-w-0 w-full">
            <ProductImageGallery images={product.images} productHandle={product.handle} />
          </div>

          <aside class="min-w-0 bg-paper lg:sticky lg:top-0 lg:h-screen lg:self-start lg:overflow-y-auto lg:border-l lg:border-line">
            <div class="flex min-h-full min-w-0 flex-col px-4 pb-8 pt-5 md:px-8 lg:px-[7.5vw] lg:py-[14vh]">
              <ProductInformations
                title={product.title}
                price={firstVariant?.price}
                quote={productQuote?.quote}
              />

              <div class="pt-6">
                <AddToCartForm
                  client:load
                  variantId={firstVariant?.id ?? ""}
                  variantQuantityAvailable={firstVariant?.quantityAvailable ?? 0}
                  variantAvailableForSale={firstVariant?.availableForSale ?? false}
                  variants={allVariants}
                  product={product}
                  colorLabel={inferredColor}
                />
              </div>

              <div class="mt-6 border-t border-line font-sans text-ink">
                <p class="border-b border-line py-5 text-sm leading-relaxed">
                  Free standard shipping in US for orders over $100 USD. Exclusions apply.
                </p>
                <details open class="group border-b border-line">
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-5 py-5 text-sm font-semibold uppercase [&::-webkit-details-marker]:hidden">
                    <span>Product Details</span>
                    <span class="text-lg leading-none transition-transform group-open:rotate-90" aria-hidden="true">›</span>
                  </summary>
                  <div class="pb-5 pr-6 font-sans text-sm leading-relaxed text-muted">
                    <p>
                      100% hand made in Los Angeles, California. Custom designed by artist Jimmy Wong on a premium heavyweight 100% USA cotton t-shirt with a thick screenprinted front and back graphic.
                    </p>
                    <ul class="mt-4 space-y-2">
                      <li>Premium heavyweight Revenant Edge blank t-shirt</li>
                      <li>Heavy screenprint on back and front</li>
                      <li>Oversized fit</li>
                      <li>Made in USA</li>
                    </ul>
                  </div>
                </details>
                <a
                  href="/pages/size-guide"
                  class="flex items-center justify-between gap-5 border-b border-line py-5 text-sm font-semibold uppercase"
                >
                  <span>Size Guide</span>
                  <span class="text-lg leading-none" aria-hidden="true">›</span>
                </a>
                <a
                  href="/pages/returns-exchanges-and-refunds"
                  class="flex items-center justify-between gap-5 border-b border-line py-5 text-sm font-semibold uppercase"
                >
                  <span>Shipping &amp; Returns</span>
                  <span class="text-lg leading-none" aria-hidden="true">›</span>
                </a>
              </div>
            </div>
          </aside>
        </div>
      </section>

      {/*
        view_item — fires on PDP load.
        Data is embedded in JSON islands, then a Vite-processed module reads it.
      */}
      <script type="application/json" id="__pdp_product_data__" set:html={analyticsProduct}></script>
      <script type="application/json" id="__pdp_variant_data__" set:html={analyticsVariant}></script>
      <script>
        import { trackViewItem } from "../../utils/analytics";
        try {
          const productEl = document.getElementById("__pdp_product_data__");
          const variantEl = document.getElementById("__pdp_variant_data__");
          if (productEl) {
            const product = JSON.parse(productEl.textContent || "null");
            const variant = variantEl ? JSON.parse(variantEl.textContent || "null") : null;
            if (product) trackViewItem(product, variant);
          }
        } catch (_) {
          // parse failure — analytics non-blocking
        }
      </script>

      <ProductFeatureSplit productHandle={product.handle} />
      <ProductRecommendations
        productId={product.id}
        buyerIP={ip}
        heading={recommendationCollection.heading}
        collectionHandle={recommendationCollection.handle}
        collectionHref={recommendationCollection.href}
        collectionGroup={recommendationCollection.group}
        ctaLabel={recommendationCollection.ctaLabel}
      />
      <TrustpilotReviews />
    </BaseLayout>
  )
}
