---
import { getProductByHandle } from "./../../utils/shopify";
import { setCache } from "../../utils/cache";
import { gmcId } from "../../utils/analytics";

import BaseLayout from "../../layouts/BaseLayout.astro";
import NotFoundLayout from "../../layouts/NotFoundLayout.astro";
import AddToCartForm from "../../components/AddToCartForm.svelte";
import ProductImageGallery from "../../components/ProductImageGallery.astro";
import ProductInformations from "../../components/ProductInformations.astro";
import ProductRecommendations from "../../components/ProductRecommendations.astro";
import ProductReviews from "../../components/ProductReviews.astro";
import ProductAccordions from "../../components/ProductAccordions.astro";

const { handle } = Astro.params;
const headers = Astro.request.headers;
const ip = headers.get("x-vercel-forwarded-for") || Astro.clientAddress;
const product = await getProductByHandle({ handle: handle || "", buyerIP: ip });

if (!product) {
  Astro.response.status = 404;
}

const firstVariant = product?.variants.nodes[0];
const allVariants = product?.variants.nodes ?? [];
setCache.short(Astro);

const colorSwatches: Record<string, string> = {
  black: "#0A0A0A",
  white: "#FFFFFF",
  cobalt: "#2747B8",
  storm: "#777D88",
  mushroom: "#B9AC9B",
  ash: "#D3D3D3",
  cream: "#E8E1D2",
};

function inferColor(input = "") {
  const source = input.toLowerCase();
  const color = Object.keys(colorSwatches).find((name) => {
    const pattern = new RegExp(`(^|[^a-z])${name}([^a-z]|$)`, "i");
    return pattern.test(source);
  });

  return color ? color[0].toUpperCase() + color.slice(1) : "Black";
}

function baseHandle(currentHandle = "") {
  return currentHandle.replace(/-(black|white|cobalt|storm|mushroom|ash|cream)$/i, "");
}

const inferredColor = product
  ? inferColor([
      product.title,
      product.handle,
      product.featuredImage?.altText,
      product.featuredImage?.url,
    ].filter(Boolean).join(" "))
  : "Black";
const colorOptions = product
  ? ["Black", "White"].map((color) => ({
      color,
      href: `/products/${baseHandle(product.handle)}-${color.toLowerCase()}`,
      active: color.toLowerCase() === inferredColor.toLowerCase(),
      swatch: colorSwatches[color.toLowerCase()],
      image: product.featuredImage
        ? {
            ...product.featuredImage,
            url: product.featuredImage.url.replace(
              /_(BLACK|WHITE)(?=[_.?])/i,
              `_${color.toUpperCase()}`
            ),
          }
        : null,
    }))
  : [];

// ── JSON-LD + view_item data (computed server-side, product is known to exist here) ──
const pdpProduct = product
  ? {
      id: product.id,
      title: product.title,
      variants: product.variants,
      featuredImage: product.featuredImage,
    }
  : null;
const pdpFirstVariant = firstVariant ?? null;

// JSON-LD Product schema for Google Shopping / rich results (SSR only)
const jsonLd = product && firstVariant
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      name: product.title,
      image: product.featuredImage?.url ?? product.images?.nodes?.[0]?.url ?? "",
      description: "",  // No description field in Storefront API result; enrich if added later
      brand: {
        "@type": "Brand",
        name: "Revenant Edge",
      },
      sku: gmcId(product.id, firstVariant.id),
      mpn: gmcId(product.id, firstVariant.id),
      productID: gmcId(product.id, firstVariant.id),
      offers: {
        "@type": "Offer",
        url: `https://revenantedge.com/products/${product.handle}`,
        priceCurrency: "USD",
        price: firstVariant.price?.amount ?? "0",
        availability: firstVariant.availableForSale
          ? "https://schema.org/InStock"
          : "https://schema.org/OutOfStock",
      },
    })
  : null;

// Serialise minimal product/variant data for the client-side view_item call
const analyticsProduct = pdpProduct ? JSON.stringify(pdpProduct) : "null";
const analyticsVariant = pdpFirstVariant ? JSON.stringify(pdpFirstVariant) : "null";
---

{
  !product ? (
    <NotFoundLayout title="Product not found" message="Product not found" />
  ) : (
    <BaseLayout title={product.title} solidHeader={true}>
      <!-- JSON-LD Product schema (SSR, for Google Shopping) -->
      {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

      <section class="border-t border-line px-0">
        <div
          class="mx-auto grid max-w-[1920px] grid-cols-1 lg:grid-cols-[minmax(0,62fr)_minmax(390px,38fr)]"
        >
          <div class="w-full">
            <ProductImageGallery images={product.images} />
          </div>

          <aside class="border-l border-line bg-paper lg:sticky lg:top-0 lg:h-screen lg:self-start lg:overflow-y-auto">
            <div class="px-6 py-6 md:px-8">
              <ProductInformations title={product.title} price={firstVariant?.price} />

              <div class="mt-5 space-y-2 border-b border-line pb-5 font-sans text-sm text-muted">
                <p>
                  Pre-order now, ships in limited batches.
                </p>
                <p>
                  {product.title.includes("Hoodie")
                    ? "Oversized fit, size down for a regular fit."
                    : "True to size, relaxed through the body."}
                </p>
                <p>
                  Model is 6 ft and wears a size large.
                </p>
              </div>

              <div class="border-b border-line py-5">
                <div class="mb-4 flex items-center justify-between">
                  <div class="flex items-baseline gap-6">
                    <p class="font-sans text-sm font-semibold text-ink">Color</p>
                    <p class="font-sans text-sm font-semibold text-muted">{inferredColor}</p>
                    <p class="font-sans text-xs text-muted">{colorOptions.length}</p>
                  </div>
                  <a href="/collections/shop-all" class="font-sans text-sm font-semibold text-ink">More Colors ›</a>
                </div>
                <div class="flex items-center gap-2 overflow-x-auto">
                  {colorOptions.map((option) => (
                    <a
                      href={option.href}
                      aria-label={`View ${option.color}`}
                      aria-current={option.active ? "true" : undefined}
                      class:list={[
                        "relative flex h-20 w-20 shrink-0 items-center justify-center bg-surface",
                        option.active && "after:absolute after:bottom-0 after:left-0 after:right-0 after:h-0.5 after:bg-ink",
                      ]}
                    >
                      {option.image ? (
                        <img
                          src={`${option.image.url}&width=220`}
                          alt={`${product.title} in ${option.color}`}
                          width={option.image.width}
                          height={option.image.height}
                          loading="lazy"
                          class="h-full w-full object-contain p-2"
                        />
                      ) : (
                        <span
                          class="h-8 w-8 rounded-full border border-line"
                          style={`background-color: ${option.swatch};`}
                        ></span>
                      )}
                    </a>
                  ))}
                </div>
              </div>

              <div class="py-5">
                <AddToCartForm
                  client:load
                  variantId={firstVariant?.id ?? ""}
                  variantQuantityAvailable={firstVariant?.quantityAvailable ?? 0}
                  variantAvailableForSale={firstVariant?.availableForSale ?? false}
                  variants={allVariants}
                  product={product}
                />
              </div>

              <div class="grid text-ink">
                {[
                  ["Try on in-store", "Check availability at a Revenant Edge partner location."],
                  ["Free shipping", "Complimentary standard shipping on orders over $100."],
                  ["Easy returns", "Return unworn pieces within 30 days."],
                ].map(([title, body]) => (
                  <div class="bg-paper px-0 py-4">
                    <p class="font-sans text-sm font-semibold">{title}</p>
                    <p class="mt-1 font-sans text-xs leading-relaxed text-muted">{body}</p>
                  </div>
                ))}
              </div>

              <div class="mt-5 bg-ink p-5 text-paper">
                <p class="font-display text-lg font-bold uppercase leading-none">Revenant Prestige</p>
                <p class="mt-3 max-w-[30ch] font-sans text-xs leading-relaxed text-paper/70">
                  Join the drop list for early access, release alerts, and member rewards.
                </p>
                <a href="/collections/demon-slayer" class="nav-label mt-5 inline-flex bg-paper px-4 py-3 text-ink">
                  Join now
                </a>
              </div>

              <div class="mt-6">
                <ProductAccordions />
              </div>
            </div>
          </aside>
        </div>
      </section>

      <section>
        <ProductRecommendations productId={product.id} buyerIP={ip} heading="Style With" />
        <ProductReviews productTitle={product.title} />
      </section>

      {/*
        view_item — fires on PDP load.
        Data is embedded in JSON islands, then a Vite-processed module reads it.
      */}
      <script type="application/json" id="__pdp_product_data__" set:html={analyticsProduct}></script>
      <script type="application/json" id="__pdp_variant_data__" set:html={analyticsVariant}></script>
      <script>
        import { trackViewItem } from "../../utils/analytics";
        try {
          const productEl = document.getElementById("__pdp_product_data__");
          const variantEl = document.getElementById("__pdp_variant_data__");
          if (productEl) {
            const product = JSON.parse(productEl.textContent || "null");
            const variant = variantEl ? JSON.parse(variantEl.textContent || "null") : null;
            if (product) trackViewItem(product, variant);
          }
        } catch (_) {
          // parse failure — analytics non-blocking
        }
      </script>
    </BaseLayout>
  )
}
