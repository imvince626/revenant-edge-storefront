---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NotFoundLayout from "../../layouts/NotFoundLayout.astro";
import { getBlogByHandle } from "../../utils/shopify";
import { setCache } from "../../utils/cache";

const { blog: blogHandle } = Astro.params;
const headers = Astro.request.headers;
const ip = headers.get("x-vercel-forwarded-for") || Astro.clientAddress;
const blog = blogHandle
  ? await getBlogByHandle({ handle: blogHandle, limit: 24, buyerIP: ip }).catch(() => null)
  : null;

if (!blog) {
  Astro.response.status = 404;
}

const description =
  blog?.seo?.description ?? `Stories, lookbooks, and release notes from ${blog?.title ?? "Revenant Edge"}.`;

setCache.short(Astro);
---

{
  !blog ? (
    <NotFoundLayout title="Blog not found" message="Blog not found" />
  ) : (
    <BaseLayout title={`${blog.title} | Revenant Edge`} description={description} solidHeader={true}>
      <section class="bg-paper px-6 py-16 text-ink md:px-10 md:py-24">
        <div class="mx-auto max-w-6xl">
          <h1 class="font-display text-[clamp(2.5rem,6vw,5rem)] font-bold uppercase leading-[0.92] tracking-normal">
            {blog.title}
          </h1>
          <div class="mt-12 grid gap-px bg-line md:grid-cols-2">
            {blog.articles.nodes.length > 0 ? (
              blog.articles.nodes.map((article) => article && (
                <a href={`/blogs/${blog.handle}/${article.handle}`} class="group bg-paper">
                  {article.image?.url && (
                    <img
                      src={`${article.image.url}${article.image.url.includes("?") ? "&" : "?"}width=900`}
                      alt={article.image.altText ?? article.title}
                      width={article.image.width}
                      height={article.image.height}
                      class="aspect-[4/3] w-full bg-surface object-cover"
                      loading="lazy"
                    />
                  )}
                  <div class="p-6">
                    <h2 class="font-sans text-lg font-semibold tracking-normal text-ink">{article.title}</h2>
                    {article.excerpt && (
                      <p class="mt-3 font-sans text-sm leading-relaxed text-muted">{article.excerpt}</p>
                    )}
                    <p class="nav-label mt-6 text-ink">Read</p>
                  </div>
                </a>
              ))
            ) : (
              <div class="bg-paper p-8">
                <p class="font-sans text-sm text-muted">No articles are published yet.</p>
              </div>
            )}
          </div>
        </div>
      </section>
    </BaseLayout>
  )
}
