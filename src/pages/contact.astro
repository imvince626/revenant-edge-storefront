---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact Us | Revenant Edge" solidHeader={true}>
  <section class="bg-paper px-6 py-24 text-ink md:px-12 md:py-32">
    <div class="mx-auto max-w-4xl">
      <h1 class="font-display text-[clamp(2.8rem,7vw,6rem)] font-bold uppercase leading-[0.92] tracking-normal">
        Contact Us
      </h1>
      <p class="mt-10 max-w-2xl font-sans text-sm leading-relaxed text-muted md:text-base">
        For order questions, sizing help, retail inquiries, or upcoming drop information, contact the Revenant Edge team.
      </p>
      <a
        href="mailto:hello@revenantedge.com"
        class="mt-12 inline-flex min-h-12 items-center justify-center bg-ink px-7 font-display text-xs font-semibold uppercase text-paper transition hover:bg-ember-700 focus:outline-none focus:ring-2 focus:ring-ink focus:ring-offset-2"
      >
        Email Us
      </a>
    </div>
  </section>
</BaseLayout>
