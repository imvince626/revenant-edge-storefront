---
import { getCollectionByHandle } from "../utils/shopify";
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeMediaPanel from "../components/home/HomeMediaPanel.astro";
import NewsletterModal from "../components/home/NewsletterModal.svelte";
import { setCache } from "../utils/cache";

// ── Buyer IP ───────────────────────────────────────────────────────────────────
const headers = Astro.request.headers;
const ip = headers.get("x-vercel-forwarded-for") || Astro.clientAddress;

setCache.short(Astro);

// ── Resilient collection fetcher ───────────────────────────────────────────────
// Returns null on any error so one bad handle never crashes the page.
async function safeCollection(handle: string) {
  try {
    return await getCollectionByHandle({ handle, limit: 12, buyerIP: ip });
  } catch (e) {
    console.error(`Collection fetch failed: ${handle}`, e);
    return null;
  }
}

// ── Parallel fetches ──────────────────────────────────────────────────────────
const [demonSlayer] =
  await Promise.all([
    safeCollection("demon-slayer"),
  ]);

// ── Convert collection image to BannerMedia for editorial sections ─────────────
// Returns undefined when the collection has no image; components render their
// built-in placeholder in that case.
const bannerMedia = (c: typeof demonSlayer) =>
  c?.image
    ? { src: c.image.url, alt: c.image.altText ?? c.title }
    : undefined;

const panels = [
  {
    media: {
      type: "video" as const,
      webm: "/hero-loop.webm",
      mp4: "/hero-loop.mp4",
      poster: "/hero-loop-poster.jpg",
    },
    eyebrow: "Now Live",
    title: "Children of the Sea Collection",
    cta: { label: "SHOP NOW", href: "/collections/collection-1-children-of-the-sea" },
    priority: true,
  },
  {
    media: {
      type: "video" as const,
      mp4: "/videos/demon-slayer-home.mp4",
      poster: bannerMedia(demonSlayer)?.src ?? "/hero-loop-poster.jpg",
    },
    eyebrow: "Set Your Heart Ablaze",
    title: "Demon Slayer Collection",
    cta: { label: "NOW LIVE", href: "/collections/demon-slayer" },
  },
  {
    media: {
      src: "/images/behind-the-brand-los-angeles.jpg",
      alt: "Los Angeles skyline at golden hour",
    },
    eyebrow: "Behind the Brand",
    title: "About Revenant Edge",
    cta: { label: "LEARN MORE", href: "/about" },
  },
];
---

<BaseLayout title="Revenant Edge — Hand-Finished Apparel" solidHeader={false}>
  {panels.map((panel) => (
    <HomeMediaPanel
      media={panel.media}
      eyebrow={panel.eyebrow}
      title={panel.title}
      cta={panel.cta}
      priority={panel.priority}
    />
  ))}

  <NewsletterModal client:idle discount="15%" delayMs={1600} />

</BaseLayout>
