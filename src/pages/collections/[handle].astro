---
import { getCollectionByHandle } from "../../utils/shopify";
import { setCache } from "../../utils/cache";

import BaseLayout from "../../layouts/BaseLayout.astro";
import NotFoundLayout from "../../layouts/NotFoundLayout.astro";
import ProductCard from "../../components/ProductCard.astro";

const { handle } = Astro.params;
const headers = Astro.request.headers;
const ip = headers.get("x-vercel-forwarded-for") || Astro.clientAddress;

const collection = await getCollectionByHandle({
  handle: handle || "",
  limit: 48,
  buyerIP: ip,
});

if (!collection) {
  Astro.response.status = 404;
}

const products = collection?.products.nodes.filter(Boolean) ?? [];
const title = collection?.title ?? "Collection";
const description = collection?.description ?? "";
const productCount = products.length;
const viewingText = productCount > 0
  ? `Viewing 1 - ${productCount} out of ${productCount} products`
  : "Viewing 0 out of 0 products";
const analyticsProducts = JSON.stringify(products);
const analyticsListName = JSON.stringify(title);

setCache.short(Astro);
---

{
  !collection ? (
    <NotFoundLayout title="Collection not found" message="Collection not found" />
  ) : (
    <BaseLayout title={`${title} | Revenant Edge`} description={description || `Shop ${title} from Revenant Edge.`} solidHeader={true}>
      <section class="border-b border-line bg-paper">
        <div class="px-4 pb-8 pt-10 md:px-8 md:pb-10 md:pt-14">
          <h1 class="font-display text-[clamp(2.5rem,7vw,6.5rem)] font-bold uppercase leading-none text-ink">
            {title}
          </h1>
          <p class="mt-3 font-sans text-sm text-muted">( {productCount} products)</p>
          {description && (
            <p class="mt-5 max-w-[52ch] font-sans text-sm leading-relaxed text-muted">
              {description}
            </p>
          )}
        </div>
      </section>

      <section class="border-b border-line bg-paper">
        <div class="grid min-h-14 grid-cols-[1fr_auto] items-center divide-x divide-line">
          <div class="flex items-center gap-5 px-4 md:px-8">
            <button class="font-sans text-sm font-semibold text-ink" type="button">
              Filter
            </button>
            <span class="font-sans text-sm text-muted">{productCount} Filter</span>
          </div>
          <div class="flex items-center gap-4 px-4 md:px-8">
            <span class="font-sans text-sm font-semibold text-ink">View</span>
            <span class="grid h-5 w-5 grid-cols-2 gap-[3px]" aria-hidden="true">
              <span class="bg-ink"></span>
              <span class="bg-ink"></span>
              <span class="bg-ink"></span>
              <span class="bg-ink"></span>
            </span>
          </div>
        </div>
      </section>

      <section class="border-b border-line bg-paper">
        <div class="grid grid-cols-1 md:grid-cols-[minmax(220px,24vw)_1fr]">
          <aside class="border-b border-line px-4 py-5 md:border-b-0 md:border-r md:px-8 md:py-6">
            <div class="flex items-center justify-between gap-4">
              <h2 class="font-sans text-sm font-semibold text-ink">Applied Filters</h2>
              <button class="font-sans text-[11px] font-semibold uppercase tracking-normal text-muted underline underline-offset-4" type="button">
                Clear Selection
              </button>
            </div>
            <p class="mt-5 font-sans text-sm text-muted">No filters applied</p>
          </aside>

          <div class="px-4 py-5 md:px-8 md:py-6">
            <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
              <div>
                <h2 class="font-sans text-sm font-semibold text-ink">Sort By</h2>
                <div class="mt-4 flex flex-wrap gap-x-8 gap-y-3">
                  {["Latest/Newest", "Most Popular", "Price: High to low", "Price: Low to high"].map((option) => (
                    <button class="font-sans text-sm text-muted transition-colors hover:text-ink" type="button">
                      {option}
                    </button>
                  ))}
                </div>
              </div>
              <div class="flex gap-2">
                <button class="min-w-28 bg-ink px-5 py-3 font-sans text-xs font-semibold uppercase tracking-normal text-paper" type="button">
                  Apply
                </button>
                <button class="min-w-28 border border-line px-5 py-3 font-sans text-xs font-semibold uppercase tracking-normal text-ink" type="button">
                  Clear
                </button>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-paper" aria-labelledby="collection-products-heading">
        <h2 id="collection-products-heading" class="sr-only">Products in {title} collection:</h2>
        {productCount > 0 ? (
          <div class="grid grid-cols-2 gap-x-px gap-y-8 px-px py-px md:grid-cols-3 xl:grid-cols-4">
            {products.map((product) => <ProductCard product={product} />)}
          </div>
        ) : (
          <div class="flex min-h-[32vh] flex-col items-center justify-center px-6 text-center">
            <p class="nav-label text-muted">No products published yet</p>
            <a href="/" class="nav-label mt-5 text-ink underline underline-offset-4">Back to home</a>
          </div>
        )}
      </section>

      <section class="border-y border-line bg-paper px-4 py-6 md:px-8">
        <div class="mx-auto flex max-w-2xl flex-col items-center gap-4 text-center">
          <button class="w-full border border-ink px-8 py-3 font-sans text-sm font-semibold uppercase tracking-normal text-ink transition-colors hover:bg-ink hover:text-paper md:w-auto" type="button">
            Load More
          </button>
          <p class="font-sans text-sm text-muted">{viewingText}</p>
        </div>
      </section>

      <nav class="border-b border-line bg-paper px-4 py-5 md:px-8" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-2 font-sans text-xs text-muted">
          <li><a class="text-ink underline underline-offset-4" href="/">Home</a></li>
          <li aria-hidden="true">/</li>
          <li>{title}</li>
        </ol>
      </nav>

      <section class="border-b border-line bg-paper px-4 py-8 md:px-8 md:py-10">
        <div class="flex items-center justify-between gap-4">
          <h2 class="font-sans text-xl font-semibold text-ink md:text-2xl">Recently Viewed Items</h2>
          <div class="flex items-center gap-5 font-sans text-sm text-muted" aria-hidden="true">
            <span>Prev</span>
            <span>Next</span>
          </div>
        </div>
        <div class="mt-8 min-h-28 border border-line bg-surface px-5 py-8">
          <p class="font-sans text-sm text-muted">Your recently viewed products will appear here.</p>
        </div>
      </section>

      <section class="bg-ink px-4 py-10 text-paper md:px-8 md:py-14">
        <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
          <div>
            <p class="font-display text-3xl font-bold uppercase leading-none md:text-5xl">Join Revenant Prestige Loyalty</p>
            <p class="mt-4 max-w-[42rem] font-sans text-sm leading-relaxed text-faint">
              Unlock 10% off your first purchase plus more rewards and benefits.
            </p>
          </div>
          <a href="/account" class="inline-flex justify-center border border-paper px-8 py-3 font-sans text-xs font-semibold uppercase tracking-normal text-paper transition-colors hover:bg-paper hover:text-ink">
            Sign Up
          </a>
        </div>
      </section>

      <script type="application/json" id="__collection_list_data__" set:html={analyticsProducts}></script>
      <script type="application/json" id="__collection_list_name__" set:html={analyticsListName}></script>
      <script>
        import { trackViewItemList } from "../../utils/analytics";
        try {
          const dataEl = document.getElementById("__collection_list_data__");
          const nameEl = document.getElementById("__collection_list_name__");
          if (dataEl && nameEl) {
            const products = JSON.parse(dataEl.textContent || "[]");
            const name = JSON.parse(nameEl.textContent || '"Collection"');
            trackViewItemList(name, products);
          }
        } catch (_) {
          // Analytics is non-blocking.
        }
      </script>
    </BaseLayout>
  )
}
