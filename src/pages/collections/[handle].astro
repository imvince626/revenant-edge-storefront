---
import { getCollectionByHandle } from "../../utils/shopify";
import { setCache } from "../../utils/cache";

import BaseLayout from "../../layouts/BaseLayout.astro";
import NotFoundLayout from "../../layouts/NotFoundLayout.astro";
import ProductCard from "../../components/ProductCard.astro";

const { handle } = Astro.params;
const headers = Astro.request.headers;
const ip = headers.get("x-vercel-forwarded-for") || Astro.clientAddress;

const collection = await getCollectionByHandle({
  handle: handle || "",
  limit: 48,
  buyerIP: ip,
});

if (!collection) {
  Astro.response.status = 404;
}

const products = collection?.products.nodes.filter(Boolean) ?? [];
const storefrontProducts = products.filter((product) => !/-white$/i.test(product.handle));
const rawTitle = collection?.title ?? "Collection";
const rawDescription = collection?.description ?? "";
const copyOverrides: Record<string, { title: string; description: string }> = {
  "shop-all": {
    title: "Shop All",
    description: "All designs by Jimmy Wong. Limited edition.",
  },
  "collection-1-children-of-the-sea": {
    title: "Collection 1: Children of the Sea",
    description: "Inspired by One Piece. Limited edition designs by Jimmy Wong",
  },
  "demon-slayer": {
    title: "Collection 2: Set Your Heart Ablaze",
    description: "Inspired by Demon Slayer. Designs by Jimmy Wong.",
  },
};
const collectionBanners: Record<string, { src: string; alt: string; objectPosition: string }> = {
  "collection-1-children-of-the-sea": {
    src: "/images/collection-banners/collection-1-children-of-the-sea.webp",
    alt: "Model wearing a Revenant Edge Children of the Sea tee",
    objectPosition: "center center",
  },
  "demon-slayer": {
    src: "/images/collection-banners/collection-2-demon-slayer.webp",
    alt: "Model wearing a Revenant Edge Demon Slayer inspired tee",
    objectPosition: "center 42%",
  },
};
const copy = copyOverrides[handle ?? ""];
const collectionBanner = collectionBanners[handle ?? ""];
const title = copy?.title ?? rawTitle;
const description = copy?.description ?? rawDescription;
const productFamilies = Array.from(
  storefrontProducts.reduce((families, product) => {
    const key = product.title;
    const existing = families.get(key) ?? [];
    existing.push(product);
    families.set(key, existing);
    return families;
  }, new Map<string, typeof storefrontProducts>())
).map(([title, familyProducts]) => ({
  title,
  product: familyProducts.find((product) => /black/i.test(product.handle)) ?? familyProducts[0],
  colorProducts: familyProducts,
}));
const displayCount = productFamilies.length;
const collectionStory = description || `${title} brings Revenant Edge graphic staples into one place. Limited-run tees and hoodies sit alongside artwork-led pieces made for everyday wear, with new drops added as they go live.`;
const analyticsProducts = JSON.stringify(productFamilies.map((family) => family.product));
const analyticsListName = JSON.stringify(title);

setCache.short(Astro);
---

{
  !collection ? (
    <NotFoundLayout title="Collection not found" message="Collection not found" />
  ) : (
    <BaseLayout title={`${title} | Revenant Edge`} description={description || `Shop ${title} from Revenant Edge.`} solidHeader={true}>
      {collectionBanner ? (
        <section class="relative border-b border-line bg-ink">
          <div class="relative min-h-[430px] overflow-hidden md:min-h-[460px] lg:min-h-[520px]">
            <img
              src={collectionBanner.src}
              alt={collectionBanner.alt}
              class="absolute inset-0 h-full w-full object-cover"
              style={`object-position: ${collectionBanner.objectPosition};`}
              loading="eager"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/25 to-black/5"></div>
            <div class="absolute inset-x-0 bottom-0 px-5 py-6 md:px-8 md:py-8">
              <div class="max-w-[56rem] text-paper">
                <h1 class="font-sans text-[24px] font-semibold leading-tight tracking-normal md:text-[36px] lg:text-[46px]">
                  {title}
                  <sup class="ml-2 align-super font-sans text-[10px] font-normal text-paper/75 md:text-[13px]">{displayCount}</sup>
                </h1>
                <p class="mt-3 max-w-[44rem] font-sans text-[13px] font-semibold leading-relaxed text-paper md:text-[15px]">
                  {collectionStory}
                </p>
              </div>
            </div>
          </div>
        </section>
      ) : (
        <section class="bg-paper px-5 py-8 md:px-8 md:py-10">
          <div class="max-w-[88rem]">
            <h1 class="font-sans text-[15px] font-semibold leading-tight text-ink">
              {title}
              <sup class="ml-1 align-super font-sans text-[10px] font-normal text-muted">{displayCount}</sup>
            </h1>
            <p class="mt-5 max-w-[64rem] font-sans text-[13px] leading-relaxed text-ink">
              {collectionStory}
            </p>
          </div>
        </section>
      )}

      <section class="bg-paper px-5 pb-8 pt-2 md:px-8">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="font-sans text-[12px] text-ink">View</span>
            <span class="grid h-[11px] w-[18px] grid-cols-[1fr_1fr_auto] gap-[2px]" aria-hidden="true">
              <span class="bg-ink"></span>
              <span class="bg-ink"></span>
              <span class="border border-ink"></span>
            </span>
          </div>
          <p class="font-sans text-[12px] text-muted">{displayCount} styles</p>
        </div>
      </section>

      <section class="bg-paper" aria-labelledby="collection-products-heading">
        <h2 id="collection-products-heading" class="sr-only">Products in {title} collection:</h2>
        {displayCount > 0 ? (
          <div class="grid grid-cols-2 gap-x-px gap-y-10 px-px md:grid-cols-3 xl:grid-cols-4">
            {productFamilies.map((family) => <ProductCard product={family.product} colorProducts={family.colorProducts} />)}
          </div>
        ) : (
          <div class="flex min-h-[32vh] flex-col items-center justify-center px-6 text-center">
            <p class="nav-label text-muted">No products published yet</p>
            <a href="/" class="nav-label mt-5 text-ink underline underline-offset-4">Back to home</a>
          </div>
        )}
      </section>

      <nav class="bg-paper px-4 pb-5 text-center md:px-8" aria-label="Breadcrumb">
        <ol class="inline-flex flex-wrap items-center gap-2 font-sans text-[12px] text-ink">
          <li><a class="text-ink underline underline-offset-4" href="/">Home</a></li>
          <li aria-hidden="true">›</li>
          <li>{title}</li>
        </ol>
      </nav>

      <section class="border-b border-line bg-paper px-6 py-14 text-center md:px-8">
        <div class="mx-auto max-w-[58rem]">
          <p class="font-sans text-[13px] leading-relaxed text-ink">
            {collectionStory}
          </p>
        </div>
      </section>

      <script type="application/json" id="__collection_list_data__" set:html={analyticsProducts}></script>
      <script type="application/json" id="__collection_list_name__" set:html={analyticsListName}></script>
      <script>
        import { trackViewItemList } from "../../utils/analytics";
        try {
          const dataEl = document.getElementById("__collection_list_data__");
          const nameEl = document.getElementById("__collection_list_name__");
          if (dataEl && nameEl) {
            const products = JSON.parse(dataEl.textContent || "[]");
            const name = JSON.parse(nameEl.textContent || '"Collection"');
            trackViewItemList(name, products);
          }
        } catch (_) {
          // Analytics is non-blocking.
        }
      </script>
    </BaseLayout>
  )
}
