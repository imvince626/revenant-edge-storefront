---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Retail | Revenant Edge" solidHeader={true}>
  <section class="bg-paper px-6 py-24 text-ink md:px-12 md:py-32">
    <div class="mx-auto max-w-5xl">
      <h1 class="max-w-4xl font-display text-[clamp(2.8rem,7vw,6rem)] font-bold uppercase leading-[0.92] tracking-normal">
        Stock Revenant Edge
      </h1>
      <div class="mt-10 grid gap-8 md:grid-cols-[1fr_1.1fr]">
        <p class="font-sans text-sm font-semibold leading-relaxed text-ink">
          For boutique, convention, and specialty retail inquiries, contact the Revenant Edge team with your store name, location, and expected opening order.
        </p>
        <p class="font-sans text-sm leading-relaxed text-muted md:text-base">
          Current assortments are limited-run and inventory-sensitive. We review wholesale requests manually so buyers get accurate availability before an order is placed.
        </p>
      </div>
      <a
        href="mailto:hello@revenantedge.com"
        class="mt-12 inline-flex min-h-12 items-center justify-center bg-ink px-7 font-display text-xs font-semibold uppercase text-paper transition hover:bg-ember-700 focus:outline-none focus:ring-2 focus:ring-ink focus:ring-offset-2"
      >
        Contact Retail
      </a>
    </div>
  </section>
</BaseLayout>
