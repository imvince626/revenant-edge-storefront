{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "revenant-edge-storefront",
  "main": "./dist/_worker.js/index.js",
  "compatibility_date": "2026-06-30",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}
